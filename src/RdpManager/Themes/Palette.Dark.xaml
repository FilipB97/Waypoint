<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Ciemna paleta Waypoint — kierunek „Compass" (chłodna czerń, hairline, jeden akcent), ale z
         WIDOCZNYMI powierzchniami/obramowaniami (bliżej wyglądu sprzed mockupu — panele czytelne jako
         karty, nie tylko cienka linia). Przełączana w runtime (ThemeManager) razem z motywem WPF-UI. -->
    <SolidColorBrush x:Key="Panel"      Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="RailBg"     Color="#CC161820"/>
    <SolidColorBrush x:Key="Elevated"   Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="Border"     Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="TextPrim"   Color="#E7E8EE"/>
    <SolidColorBrush x:Key="TextSec"    Color="#8A8C97"/>
    <SolidColorBrush x:Key="TextTer"    Color="#5A5C66"/>
    <SolidColorBrush x:Key="Accent"       Color="#4C86FF"/>
    <SolidColorBrush x:Key="AccentSoft"   Color="#1F4C86FF"/>
    <SolidColorBrush x:Key="AccentBright" Color="#6E9EFF"/>
    <SolidColorBrush x:Key="AccentStrong" Color="#664C86FF"/>
    <SolidColorBrush x:Key="SplitDim"     Color="#33000000"/>
    <SolidColorBrush x:Key="TextOnColor" Color="White"/>
    <SolidColorBrush x:Key="Online"     Color="#3DDC97"/>
    <SolidColorBrush x:Key="Idle"       Color="#FFB454"/>
    <SolidColorBrush x:Key="Offline"    Color="#5B5D66"/>
    <SolidColorBrush x:Key="Danger"     Color="#E8463F"/>
    <SolidColorBrush x:Key="GdProd"     Color="#7C6CFB"/>
    <SolidColorBrush x:Key="GdStaging"  Color="#FFB454"/>
    <SolidColorBrush x:Key="GdClient"   Color="#36B8C4"/>

    <!-- Kolory etykiet protokołów (Compass §2) — używane od Fazy 2 (świadoma protokołów lista). -->
    <SolidColorBrush x:Key="ProtoRdp"    Color="#7BA6FF"/>
    <SolidColorBrush x:Key="ProtoSsh"    Color="#4BD6A0"/>
    <SolidColorBrush x:Key="ProtoSftp"   Color="#F0B45F"/>
    <SolidColorBrush x:Key="ProtoRest"   Color="#48C6CF"/>
    <SolidColorBrush x:Key="ProtoWeb"    Color="#9C93FF"/>
    <SolidColorBrush x:Key="ProtoTelnet" Color="#C0C3CC"/>

    <!-- Kolory metod REST (Compass §2) — używane od Fazy 7 (badge metody). -->
    <SolidColorBrush x:Key="MethodGet"    Color="#3DDC97"/>
    <SolidColorBrush x:Key="MethodPost"   Color="#4C86FF"/>
    <SolidColorBrush x:Key="MethodPut"    Color="#FFB454"/>
    <SolidColorBrush x:Key="MethodDelete" Color="#E8463F"/>
    <SolidColorBrush x:Key="MethodPatch"  Color="#7C6CFB"/>

    <FontFamily x:Key="Mono">Cascadia Code, Consolas, monospace</FontFamily>

    <LinearGradientBrush x:Key="AvProd" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7C6CFB" Offset="0"/><GradientStop Color="#4F3FD1" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AvStaging" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFB454" Offset="0"/><GradientStop Color="#D98F2E" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AvClient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#36C4CF" Offset="0"/><GradientStop Color="#1F8B94" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LogoBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3A6BE8" Offset="0"/><GradientStop Color="#2657D6" Offset="1"/>
    </LinearGradientBrush>
    <!-- Tło: chłodna czerń z lekkim uniesieniem i gradientem (bliżej wyglądu sprzed mockupu — mniej płasko). -->
    <LinearGradientBrush x:Key="CanvasBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F1014" Offset="0"/><GradientStop Color="#181A22" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Canvas" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F1014" Offset="0"/><GradientStop Color="#181A22" Offset="1"/>
    </LinearGradientBrush>

    <!-- Nakładki (pasek pełnoekranowy / flyout / hover raila) — zależne od motywu. -->
    <SolidColorBrush x:Key="FsBarBg" Color="#DD212226"/>
    <SolidColorBrush x:Key="FsFlyoutBg" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="RailHover" Color="#14FFFFFF"/>
</ResourceDictionary>
