<ui:FluentWindow x:Class="RdpManager.CredentialPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Poświadczenia" Width="400" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Poświadczenia"/>

        <StackPanel Grid.Row="1" Margin="18,8,18,8">
            <TextBlock x:Name="PromptHeader" TextWrapping="Wrap" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

            <TextBlock Text="Użytkownik" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="UserBox"/>

            <TextBlock Text="Domena (opcjonalnie)" Margin="0,10,0,4"/>
            <ui:TextBox x:Name="DomainBox"/>

            <TextBlock Text="Hasło" Margin="0,10,0,4"/>
            <PasswordBox x:Name="PassBox" VerticalContentAlignment="Center"/>

            <CheckBox x:Name="SavePassCheck" Content="Zapisz hasło (Windows Credential Manager)" Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,4,18,16">
            <ui:Button Content="Anuluj" Appearance="Secondary" Click="Cancel_Click" Margin="0,0,8,0" MinWidth="90"/>
            <ui:Button Content="Połącz" Appearance="Primary" Click="Ok_Click" MinWidth="90" IsDefault="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
