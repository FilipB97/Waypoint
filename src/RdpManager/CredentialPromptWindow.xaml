<ui:FluentWindow x:Class="RdpManager.CredentialPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource S.cp.title}" Width="400" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource S.cp.title}"/>

        <!-- Treść przewija się; przyciski zawsze widoczne. -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="18,8,18,8">
            <TextBlock x:Name="PromptHeader" TextWrapping="Wrap" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

            <TextBlock Text="{DynamicResource S.se.user}" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="UserBox"/>

            <TextBlock Text="{DynamicResource S.cp.domainopt}" Margin="0,10,0,4"/>
            <ui:TextBox x:Name="DomainBox"/>

            <TextBlock Text="{DynamicResource S.pass}" Margin="0,10,0,4"/>
            <PasswordBox x:Name="PassBox" VerticalContentAlignment="Center"/>

            <CheckBox x:Name="SavePassCheck" Margin="0,10,0,0">
                <TextBlock Text="{DynamicResource S.se.savepass}" TextWrapping="Wrap"/>
            </CheckBox>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,4,18,16">
            <ui:Button Content="{DynamicResource S.cancel}" Appearance="Secondary" Click="Cancel_Click" Margin="0,0,8,0" MinWidth="90" IsCancel="True"/>
            <ui:Button Content="{DynamicResource S.connect}" Appearance="Primary" Click="Ok_Click" MinWidth="90" IsDefault="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
