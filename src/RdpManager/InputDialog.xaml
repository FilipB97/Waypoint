<ui:FluentWindow x:Class="RdpManager.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="" Width="380" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="WinTitleBar" Grid.Row="0" Title=""/>

        <StackPanel Grid.Row="1" Margin="18,8,18,8">
            <TextBlock x:Name="PromptLabel" TextWrapping="Wrap" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <ui:TextBox x:Name="InputBox"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,4,18,16">
            <ui:Button Content="Anuluj" Appearance="Secondary" Click="Cancel_Click" Margin="0,0,8,0" MinWidth="90"/>
            <ui:Button Content="OK" Appearance="Primary" Click="Ok_Click" MinWidth="90" IsDefault="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
