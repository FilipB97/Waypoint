<UserControl x:Class="RdpManager.FileTransferPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             AllowDrop="True" DragEnter="Panel_DragEnter" DragOver="Panel_DragOver"
             DragLeave="Panel_DragLeave" Drop="Panel_Drop">
    <UserControl.Resources>
        <!-- Klikalny nagłówek kolumny (sortowanie) — bez chromu, hover rozjaśnia tekst. -->
        <Style x:Key="FtHead" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTer}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSmall}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Pasek narzędzi: przezroczysty przycisk-ikona z podświetleniem akcentem (bez przygaszania ikony). -->
        <Style x:Key="FtIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource Accent}" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Border x:Name="FocusRing" CornerRadius="{StaticResource RadiusSm}" BorderThickness="2" BorderBrush="Transparent" IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="0.12" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.20"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="BorderBrush" Value="{DynamicResource Accent}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segment ścieżki (breadcrumb): link-owy przycisk. -->
        <Style x:Key="FtCrumbBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="{StaticResource RadiusSm}" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Wiersz listy: przezroczysty; hover/zaznaczenie = akcent (tło osobną warstwą, nie przygasza tekstu). -->
        <Style x:Key="FtRow" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource Accent}" Opacity="0"/>
                            <Border x:Name="HoverFill" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource Accent}" Opacity="0"/>
                            <ContentPresenter Margin="8,5" VerticalAlignment="Center"/>
                            <Border x:Name="FocusRing" CornerRadius="{StaticResource RadiusSm}" BorderThickness="2" BorderBrush="Transparent" IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="0.08" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.16"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="BorderBrush" Value="{DynamicResource Accent}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Szablon wiersza: ikona + nazwa (rozciąga się) + rozmiar (do prawej) + data. -->
        <DataTemplate x:Key="FtRowTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="{Binding Icon}" FontSize="{StaticResource IconMd}" Foreground="{Binding IconBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextPrim}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="6,0,8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding SizeText}" Foreground="{DynamicResource TextSec}"
                           VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0" FontSize="{StaticResource FontSmall}"/>
                <TextBlock Grid.Column="3" Text="{Binding Modified}" Foreground="{DynamicResource TextTer}"
                           VerticalAlignment="Center" FontSize="{StaticResource FontSmall}"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}" BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- pasek: breadcrumb + akcje -->
                <RowDefinition Height="Auto"/>   <!-- nagłówek kolumn -->
                <RowDefinition Height="*"/>      <!-- lista -->
                <RowDefinition Height="Auto"/>   <!-- status -->
            </Grid.RowDefinitions>

            <!-- Pasek narzędzi -->
            <Grid Grid.Row="0" Margin="6,8,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource FtIconBtn}" ToolTip="{DynamicResource S.sftp.up}" AutomationProperties.Name="{DynamicResource S.sftp.up}" Click="Up_Click">
                        <ui:SymbolIcon Symbol="ArrowUp24"/>
                    </Button>
                    <Button Style="{StaticResource FtIconBtn}" ToolTip="{DynamicResource S.sftp.refresh}" AutomationProperties.Name="{DynamicResource S.sftp.refresh}" Click="Refresh_Click">
                        <ui:SymbolIcon Symbol="ArrowClockwise24"/>
                    </Button>
                </StackPanel>

                <!-- Ścieżka jako okruszki (klik = nawigacja) -->
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="4,0">
                    <StackPanel x:Name="Breadcrumb" Orientation="Horizontal" VerticalAlignment="Center"/>
                </ScrollViewer>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="UploadBtn" Style="{StaticResource FtIconBtn}" ToolTip="{DynamicResource S.sftp.upload}" AutomationProperties.Name="{DynamicResource S.sftp.upload}" Click="Upload_Click">
                        <ui:SymbolIcon Symbol="ArrowUpload24"/>
                    </Button>
                    <Button x:Name="DownloadBtn" Style="{StaticResource FtIconBtn}" ToolTip="{DynamicResource S.sftp.download}" AutomationProperties.Name="{DynamicResource S.sftp.download}" Click="Download_Click">
                        <ui:SymbolIcon Symbol="ArrowDownload24"/>
                    </Button>
                    <Border Width="1" Margin="4,4" Background="{DynamicResource Border}"/>
                    <Button Style="{StaticResource FtIconBtn}" ToolTip="{DynamicResource S.sftp.newfolder}" AutomationProperties.Name="{DynamicResource S.sftp.newfolder}" Click="NewFolder_Click">
                        <ui:SymbolIcon Symbol="FolderAdd24"/>
                    </Button>
                    <Button x:Name="DeleteBtn" Style="{StaticResource FtIconBtn}" ToolTip="{DynamicResource S.sftp.delete}" AutomationProperties.Name="{DynamicResource S.sftp.delete}" Click="Delete_Click">
                        <ui:SymbolIcon Symbol="Delete24"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Nagłówek kolumn -->
            <Border Grid.Row="1" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Margin="12,0,14,0" Padding="0,0,0,5">
                <Grid Margin="12,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Style="{DynamicResource FtHead}" Tag="name" Click="HeaderSort_Click" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource S.sftp.name}"/>
                            <TextBlock x:Name="SortArrowName" FontSize="{StaticResource FontMicro}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Style="{DynamicResource FtHead}" Tag="size" Click="HeaderSort_Click"
                            HorizontalAlignment="Right" HorizontalContentAlignment="Right" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SortArrowSize" FontSize="{StaticResource FontMicro}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource S.sftp.size}"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" Style="{DynamicResource FtHead}" Tag="modified" Click="HeaderSort_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource S.sftp.modified}"/>
                            <TextBlock x:Name="SortArrowMod" FontSize="{StaticResource FontMicro}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Lista + nakładka „upuść, aby wysłać" -->
            <Grid Grid.Row="2">
                <ListView x:Name="FileList" BorderThickness="0" Background="Transparent" Margin="4,4,6,2"
                          SelectionMode="Extended"
                          ItemContainerStyle="{StaticResource FtRow}" ItemTemplate="{StaticResource FtRowTemplate}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          MouseDoubleClick="List_DoubleClick"
                          PreviewMouseLeftButtonDown="List_PreviewDown" PreviewMouseMove="List_PreviewMove"/>
                <Border x:Name="DropOverlay" Visibility="Collapsed" Margin="6" CornerRadius="{StaticResource RadiusLg}"
                        Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Accent}" BorderThickness="2" Opacity="0.96">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="{StaticResource IconXl}" Foreground="{DynamicResource Accent}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource S.sftp.drophint}" Foreground="{DynamicResource TextSec}" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status + postęp transferu -->
            <Grid Grid.Row="3" Margin="14,4,14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="StatusText" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}" TextTrimming="CharacterEllipsis"/>
                    <ProgressBar x:Name="TransferProgress" Visibility="Collapsed" Height="4" Margin="0,4,0,0"
                                 Minimum="0" Maximum="100"/>
                </StackPanel>
                <Button x:Name="CancelTransferBtn" Grid.Column="1" Visibility="Collapsed" Style="{StaticResource FtIconBtn}"
                        Width="24" Height="24" ToolTip="{DynamicResource S.sftp.cancel}" AutomationProperties.Name="{DynamicResource S.sftp.cancel}" Click="CancelTransfer_Click" Margin="6,0,0,0">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="{StaticResource IconSm}"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
