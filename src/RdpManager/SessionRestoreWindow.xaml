<ui:FluentWindow x:Class="RdpManager.SessionRestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource S.restore.title}" Width="430" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <Grid Background="{DynamicResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource S.restore.title}">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="History24" Foreground="{DynamicResource Accent}"/></ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="{StaticResource DialogContentMargin}">
            <TextBlock Text="{DynamicResource S.restore.msg}" TextWrapping="Wrap" Margin="0,0,0,10"
                       Foreground="{DynamicResource TextSec}"/>
            <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="List"/>
            </ScrollViewer>
            <CheckBox x:Name="DontAsk" Content="{DynamicResource S.restore.dontask}"
                      Foreground="{DynamicResource TextTer}" Margin="0,12,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogButtonRowMargin}">
            <ui:Button Content="{DynamicResource S.restore.skip}" Appearance="Secondary" Click="Skip_Click" Margin="0,0,8,0" MinWidth="90" IsCancel="True"/>
            <ui:Button Content="{DynamicResource S.restore.open}" Appearance="Primary" Click="Open_Click" MinWidth="110" IsDefault="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
