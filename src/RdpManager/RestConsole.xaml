<UserControl x:Class="RdpManager.RestConsole"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <!-- Mały przycisk-ikona (dodaj/usuń/kopiuj) — jak w panelu plików. -->
        <Style x:Key="RestIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource Accent}" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Border x:Name="FocusRing" CornerRadius="{StaticResource RadiusSm}" BorderThickness="2" BorderBrush="Transparent" IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="0.12" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.20"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="BorderBrush" Value="{DynamicResource Accent}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Zwięzła komórka tekstowa dla wierszy klucz/wartość. ToolTip=" " (placeholder) + EventSetter:
             bez początkowego ToolTip WPF nigdy nie odpali ToolTipOpening (podgląd wartości po {{podstawieniu}}). -->
        <Style x:Key="RestCell" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrim}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
            <Setter Property="ToolTip" Value=" "/>
            <EventSetter Event="ToolTipOpening" Handler="ValuePreview_ToolTipOpening"/>
        </Style>

        <!-- Wiersz klucz/wartość: przełącznik + klucz + wartość + usuń. Szerokości kolumn zsynchronizowane z nagłówkiem (KvHeader). -->
        <DataTemplate x:Key="KvRowTemplate">
            <Grid Height="34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" MinWidth="0" Padding="0"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Style="{StaticResource RestCell}" Margin="0,0,8,0"
                         Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Grid.Column="2" Style="{StaticResource RestCell}" Margin="0,0,8,0"
                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="3" Style="{StaticResource RestIconBtn}" Width="28" Height="28" Click="DeleteKv_Click"
                        ToolTip="{DynamicResource S.rest.remove}" AutomationProperties.Name="{DynamicResource S.rest.remove}">
                    <ui:SymbolIcon Symbol="Dismiss20" FontSize="{StaticResource IconSm}"/>
                </Button>
            </Grid>
        </DataTemplate>

        <!-- Pod-zakładka Compass: podkreślenie akcentem pod aktywną (jak .subtab w mockupie), bez pudełka. -->
        <Style x:Key="RestTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextTer}"/>
            <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Margin="0,0,22,0" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" Margin="0,9"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Baza = CanvasBrush jak reszta widoków (pulpit/ustawienia/sesje); panele wyróżnia hairline, nie tło. -->
    <Border Background="{DynamicResource CanvasBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lewy panel: drzewo kolekcji (foldery + żądania) -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
                <Grid Margin="8,10,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Nagłówek w DWÓCH wierszach: tytuł nad paskiem ikon. Wcześniej tytuł i pasek ikon
                         dzieliły jedną komórkę Grid i nakładały się przy wąskim panelu (150-240px). -->
                    <StackPanel Grid.Row="0" Margin="2,0,0,6">
                        <Grid Margin="0,0,4,4">
                            <TextBlock Text="{DynamicResource S.rest.collection}" Foreground="{DynamicResource TextTer}"
                                       FontWeight="Bold" FontSize="{StaticResource FontCaption}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CollCount" HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextTer}" FontFamily="{DynamicResource Mono}" FontSize="{StaticResource FontCaption}"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <ToggleButton x:Name="HistoryToggle" ToolTip="{DynamicResource S.rest.hist}" AutomationProperties.Name="{DynamicResource S.rest.hist}" Click="History_Toggled"
                                          Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="6,0" Height="28">
                                <ui:SymbolIcon Symbol="History24" FontSize="{StaticResource IconMd}"/>
                            </ToggleButton>
                            <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.authmgr.open}" AutomationProperties.Name="{DynamicResource S.rest.authmgr.open}" Click="CollectionAuth_Click">
                                <ui:SymbolIcon Symbol="Key24" FontSize="{StaticResource IconMd}"/>
                            </Button>
                            <Border Width="1" Margin="3,5" Background="{DynamicResource Border}"/>
                            <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.newreq}" AutomationProperties.Name="{DynamicResource S.rest.newreq}" Click="AddRequest_Click">
                                <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="{StaticResource IconMd}"/>
                            </Button>
                            <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.newfolder}" AutomationProperties.Name="{DynamicResource S.rest.newfolder}" Click="AddFolder_Click">
                                <ui:SymbolIcon Symbol="FolderAdd24" FontSize="{StaticResource IconMd}"/>
                            </Button>
                            <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.rename}" AutomationProperties.Name="{DynamicResource S.rest.rename}" Click="Rename_Click">
                                <ui:SymbolIcon Symbol="Rename24" FontSize="{StaticResource IconMd}"/>
                            </Button>
                            <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.delete}" AutomationProperties.Name="{DynamicResource S.rest.delete}" Click="DeleteNode_Click">
                                <ui:SymbolIcon Symbol="Delete24" FontSize="{StaticResource IconMd}"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                    <Grid Grid.Row="1">
                    <TreeView x:Name="CollTree" BorderThickness="0" Background="Transparent"
                              SelectedItemChanged="Tree_SelectionChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Border x:Name="HeaderHost" Grid.Row="0" Cursor="Hand">
                                                    <Grid>
                                                        <Border x:Name="Bd" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource Accent}" Opacity="0"/>
                                                        <Grid Margin="0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="16"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ToggleButton x:Name="Expander" Grid.Column="0" Focusable="False" ClickMode="Press"
                                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="Transparent" Width="16" Height="26">
                                                                            <ui:SymbolIcon x:Name="Chev" Symbol="ChevronRight16" FontSize="{StaticResource IconXs}" Foreground="{DynamicResource TextTer}" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="Chev" Property="Symbol" Value="ChevronDown16"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" Margin="2,4,4,4"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="12,0,0,0"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                </Trigger>
                                                <Trigger SourceName="HeaderHost" Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.08"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.16"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Height="24">
                                    <ui:SymbolIcon Symbol="{Binding Icon}" Visibility="{Binding FolderIconVis}" FontSize="{StaticResource IconMd}"
                                                   Foreground="{Binding IconBrush}" VerticalAlignment="Center"/>
                                    <Border Visibility="{Binding MethodVis}" Background="{Binding MethodBadgeBg}" CornerRadius="5"
                                            Padding="5,1" MinWidth="38" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding MethodText}" Foreground="{Binding MethodBrush}" FontFamily="{DynamicResource Mono}"
                                                   FontWeight="Bold" FontSize="9" TextAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" Margin="8,0,0,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrim}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- Historia wysłanych żądań (przełącznik w nagłówku) -->
                    <ListBox x:Name="HistoryList" Visibility="Collapsed" BorderThickness="0" Background="Transparent"
                             MouseDoubleClick="History_Activate"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Method}" FontWeight="SemiBold" Width="52"
                                                   Foreground="{DynamicResource TextSec}" FontSize="{StaticResource FontBody}"/>
                                        <TextBlock Text="{Binding Url}" Foreground="{DynamicResource TextPrim}"
                                                   TextTrimming="CharacterEllipsis" FontSize="{StaticResource FontBody}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}" Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </Grid>

                    <!-- Wybór aktywnego środowiska (zmienne {{...}}) -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,6,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.rest.env.label}" Foreground="{DynamicResource TextTer}"
                                       VerticalAlignment="Center" FontSize="{StaticResource FontBody}" Margin="2,0,6,0"/>
                            <ComboBox Grid.Column="1" x:Name="EnvCombo" SelectionChanged="EnvCombo_Changed" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.env.manage}"
                                    AutomationProperties.Name="{DynamicResource S.rest.env.manage}" Click="ManageEnv_Click" Margin="4,0,0,0">
                                <ui:SymbolIcon Symbol="Settings24" FontSize="{StaticResource IconMd}"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- Prawy panel: budowniczy żądania + odpowiedź -->
            <Grid Grid.Column="2" Margin="12,10,12,10">
                <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- pasek: metoda + URL + Wyślij/Zapisz -->
                <RowDefinition Height="1.1*" MinHeight="150"/>   <!-- żądanie: zakładki -->
                <RowDefinition Height="Auto"/>   <!-- splitter -->
                <RowDefinition Height="1*" MinHeight="120"/>     <!-- odpowiedź -->
                <RowDefinition Height="Auto"/>   <!-- status -->
            </Grid.RowDefinitions>

            <!-- Pasek żądania -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="MethodCombo" Grid.Column="0" Width="118" FontWeight="SemiBold"
                          SelectionChanged="Method_Changed" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="GET"/>
                    <ComboBoxItem Content="POST"/>
                    <ComboBoxItem Content="PUT"/>
                    <ComboBoxItem Content="PATCH"/>
                    <ComboBoxItem Content="DELETE"/>
                    <ComboBoxItem Content="HEAD"/>
                    <ComboBoxItem Content="OPTIONS"/>
                </ComboBox>
                <ui:TextBox x:Name="UrlBox" Grid.Column="1" Margin="8,0" PlaceholderText="{DynamicResource S.rest.urlph}"
                            VerticalContentAlignment="Center" FontSize="{StaticResource FontBody}"
                            ToolTip=" " ToolTipOpening="ValuePreview_ToolTipOpening"/>
                <ui:Button x:Name="SendBtn" Grid.Column="2" Appearance="Primary" Content="{DynamicResource S.rest.send}"
                           MinWidth="104" Click="Send_Click">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Send24"/></ui:Button.Icon>
                </ui:Button>
                <Button x:Name="SaveBtn" Grid.Column="3" Style="{StaticResource RestIconBtn}" Width="34" Height="34" Margin="6,0,0,0"
                        ToolTip="{DynamicResource S.rest.save}" AutomationProperties.Name="{DynamicResource S.rest.save}" Click="Save_Click">
                    <ui:SymbolIcon Symbol="Save24"/>
                </Button>
            </Grid>

            <!-- Zakładki żądania: Parametry / Nagłówki / Treść / Uwierzytelnianie -->
            <TabControl Grid.Row="1" x:Name="RequestTabs" BorderThickness="0" Background="Transparent" Padding="0,8,0,0"
                        ItemContainerStyle="{StaticResource RestTab}">
                <TabItem Header="{DynamicResource S.rest.tab.params}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="0,6,0,4" Margin="2,8,2,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.3*"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="{DynamicResource S.rest.key}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}"/>
                                <TextBlock Grid.Column="2" Text="{DynamicResource S.rest.value}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ParamsList" ItemTemplate="{StaticResource KvRowTemplate}" Margin="2,2,2,0"/>
                        </ScrollViewer>
                        <Button Grid.Row="2" HorizontalAlignment="Left" Margin="2,6,0,0" Style="{StaticResource RestIconBtn}"
                                Width="Auto" Padding="8,0" Click="AddParam_Click" Foreground="{DynamicResource Accent}"
                                AutomationProperties.Name="{DynamicResource S.rest.add}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add20" FontSize="{StaticResource IconSm}"/>
                                <TextBlock Text="{DynamicResource S.rest.add}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource S.rest.tab.headers}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="0,6,0,4" Margin="2,8,2,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.3*"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="{DynamicResource S.rest.key}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}"/>
                                <TextBlock Grid.Column="2" Text="{DynamicResource S.rest.value}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="HeadersList" ItemTemplate="{StaticResource KvRowTemplate}" Margin="2,2,2,0"/>
                        </ScrollViewer>
                        <Button Grid.Row="2" HorizontalAlignment="Left" Margin="2,6,0,0" Style="{StaticResource RestIconBtn}"
                                Width="Auto" Padding="8,0" Click="AddHeader_Click" Foreground="{DynamicResource Accent}"
                                AutomationProperties.Name="{DynamicResource S.rest.add}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add20" FontSize="{StaticResource IconSm}"/>
                                <TextBlock Text="{DynamicResource S.rest.add}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource S.rest.tab.body}">
                    <Grid Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,6">
                            <TextBlock Text="{DynamicResource S.rest.body.type}" Foreground="{DynamicResource TextTer}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontSize="{StaticResource FontBody}"/>
                            <ComboBox x:Name="ContentTypeCombo" Width="260" VerticalContentAlignment="Center"
                                      SelectionChanged="ContentType_Changed">
                                <ComboBoxItem Content="application/json"/>
                                <ComboBoxItem Content="text/plain"/>
                                <ComboBoxItem Content="application/xml"/>
                                <ComboBoxItem Content="application/x-www-form-urlencoded"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Treść surowa (JSON/XML/tekst) -->
                        <Border x:Name="BodyRawHost" Grid.Row="1" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="{StaticResource RadiusSm}">
                            <TextBox x:Name="BodyBox" BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource TextPrim}" CaretBrush="{DynamicResource TextPrim}"
                                     AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="{StaticResource FontBody}" Padding="8"/>
                        </Border>

                        <!-- Tabela klucz/wartość dla x-www-form-urlencoded (jak w Postmanie) -->
                        <Grid x:Name="FormFieldsHost" Grid.Row="1" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="0,6,0,4" Margin="2,0,2,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource S.rest.key}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}"/>
                                    <TextBlock Grid.Column="2" Text="{DynamicResource S.rest.value}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}"/>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="FormFieldsList" ItemTemplate="{StaticResource KvRowTemplate}" Margin="2,2,2,0"/>
                            </ScrollViewer>
                            <Button Grid.Row="2" HorizontalAlignment="Left" Margin="2,6,0,0" Style="{StaticResource RestIconBtn}"
                                    Width="Auto" Padding="8,0" Click="AddFormField_Click" Foreground="{DynamicResource Accent}"
                                    AutomationProperties.Name="{DynamicResource S.rest.add}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Add20" FontSize="{StaticResource IconSm}"/>
                                    <TextBlock Text="{DynamicResource S.rest.add}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource S.rest.tab.auth}">
                    <StackPanel Margin="2,10,2,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource S.rest.auth.type}" Foreground="{DynamicResource TextTer}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontSize="{StaticResource FontBody}"/>
                            <ComboBox x:Name="AuthCombo" Width="220" SelectionChanged="Auth_Changed" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="{DynamicResource S.rest.auth.none}"/>
                                <ComboBoxItem Content="{DynamicResource S.rest.auth.bearer}"/>
                                <ComboBoxItem Content="{DynamicResource S.rest.auth.basic}"/>
                                <ComboBoxItem Content="{DynamicResource S.rest.auth.inherit}"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Bearer -->
                        <StackPanel x:Name="BearerPanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource S.rest.auth.token}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontBody}" Margin="0,0,0,3"/>
                            <PasswordBox x:Name="TokenBox" MaxWidth="520" HorizontalAlignment="Left" MinWidth="360"/>
                        </StackPanel>

                        <!-- Basic -->
                        <StackPanel x:Name="BasicPanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource S.rest.auth.user}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontBody}" Margin="0,0,0,3"/>
                            <TextBox x:Name="AuthUserBox" Style="{StaticResource RestCell}" MaxWidth="520" MinWidth="360" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource S.rest.auth.pass}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontBody}" Margin="0,0,0,3"/>
                            <PasswordBox x:Name="AuthPassBox" MaxWidth="520" MinWidth="360" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Dziedzicz: skąd faktycznie weźmie auth (folder/kolekcja) — diagnostyka "czemu to nie działa" -->
                        <TextBlock x:Name="InheritHint" Visibility="Collapsed" Foreground="{DynamicResource TextTer}"
                                   FontSize="{StaticResource FontSmall}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <TextBlock x:Name="AuthHint" Text="{DynamicResource S.rest.auth.hint}" Foreground="{DynamicResource TextTer}"
                                   FontSize="{StaticResource FontSmall}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="{DynamicResource S.rest.tab.scripts}">
                    <Grid Margin="0,8,0,0" ToolTip="{DynamicResource S.rest.script.hint}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource S.rest.script.pre}" Foreground="{DynamicResource TextSec}" FontWeight="SemiBold" Margin="2,0,0,3"/>
                        <Border Grid.Row="1" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="{StaticResource RadiusSm}" Margin="0,0,0,8">
                            <TextBox x:Name="PreScriptBox" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextPrim}"
                                     CaretBrush="{DynamicResource TextPrim}" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="{StaticResource FontBody}" Padding="8"/>
                        </Border>
                        <TextBlock Grid.Row="2" Text="{DynamicResource S.rest.script.post}" Foreground="{DynamicResource TextSec}" FontWeight="SemiBold" Margin="2,0,0,3"/>
                        <Border Grid.Row="3" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="{StaticResource RadiusSm}">
                            <TextBox x:Name="TestScriptBox" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextPrim}"
                                     CaretBrush="{DynamicResource TextPrim}" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="{StaticResource FontBody}" Padding="8"/>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- Odpowiedź -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Wiersz statusu odpowiedzi -->
                <Grid Grid.Row="0" Margin="0,4,0,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="StatusPill" CornerRadius="{StaticResource RadiusSm}" Padding="8,2" Visibility="Collapsed">
                            <TextBlock x:Name="StatusPillText" FontWeight="SemiBold" FontSize="{StaticResource FontBody}" Foreground="{DynamicResource TextOnColor}"/>
                        </Border>
                        <TextBlock x:Name="MetaText" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"
                                   Margin="10,0,0,0" FontSize="{StaticResource FontBody}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ToggleButton x:Name="PrettyToggle" Content="{DynamicResource S.rest.pretty}" IsChecked="True"
                                      Click="Pretty_Changed" Padding="8,2" FontSize="{StaticResource FontSmall}" Cursor="Hand"/>
                        <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.copy}" AutomationProperties.Name="{DynamicResource S.rest.copy}" Click="CopyBody_Click" Margin="6,0,0,0">
                            <ui:SymbolIcon Symbol="Copy20" FontSize="{StaticResource IconMd}"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <TabControl Grid.Row="1" x:Name="ResponseTabs" BorderThickness="0" Background="Transparent"
                            ItemContainerStyle="{StaticResource RestTab}">
                    <TabItem Header="{DynamicResource S.rest.resp.body}">
                        <Border BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="{StaticResource RadiusSm}" Margin="0,6,0,0">
                            <!-- RichTextBox: JSON kolorowany tokenami (klucz/łańcuch/liczba/słowo kluczowe). -->
                            <RichTextBox x:Name="ResponseBody" BorderThickness="0" Background="Transparent" IsReadOnly="True"
                                         Foreground="{DynamicResource TextPrim}"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="{StaticResource FontBody}" Padding="8"/>
                        </Border>
                    </TabItem>
                    <TabItem Header="{DynamicResource S.rest.resp.headers}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
                            <ItemsControl x:Name="ResponseHeaders" Margin="2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="{DynamicResource TextSec}"
                                                       FontFamily="Consolas" FontSize="{StaticResource FontBody}" Margin="0,0,12,0" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{DynamicResource TextPrim}"
                                                       FontFamily="Consolas" FontSize="{StaticResource FontBody}" TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="{DynamicResource S.rest.resp.script}">
                        <Border BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="{StaticResource RadiusSm}" Margin="0,6,0,0">
                            <TextBox x:Name="ScriptOutput" BorderThickness="0" Background="Transparent" IsReadOnly="True"
                                     Foreground="{DynamicResource TextPrim}" AcceptsReturn="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="{StaticResource FontBody}" Padding="8"/>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>

            <TextBlock x:Name="StatusText" Grid.Row="4" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}"
                       Margin="2,6,2,0" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
