<UserControl x:Class="RdpManager.RestConsole"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <!-- Mały przycisk-ikona (dodaj/usuń/kopiuj) — jak w panelu plików. -->
        <Style x:Key="RestIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="6" Background="{DynamicResource Accent}" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.12"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.20"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Zwięzła komórka tekstowa dla wierszy klucz/wartość. -->
        <Style x:Key="RestCell" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrim}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>

        <!-- Wiersz klucz/wartość: przełącznik + klucz + wartość + usuń. Szerokości kolumn zsynchronizowane z nagłówkiem (KvHeader). -->
        <DataTemplate x:Key="KvRowTemplate">
            <Grid Height="34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Style="{StaticResource RestCell}" Margin="0,0,8,0"
                         Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Grid.Column="2" Style="{StaticResource RestCell}" Margin="0,0,8,0"
                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="3" Style="{StaticResource RestIconBtn}" Width="28" Height="28" Click="DeleteKv_Click"
                        ToolTip="{DynamicResource S.rest.remove}">
                    <ui:SymbolIcon Symbol="Dismiss20" FontSize="14"/>
                </Button>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource Panel}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lewy panel: drzewo kolekcji (foldery + żądania) -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
                <Grid Margin="8,10,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="2,0,0,6">
                        <TextBlock Text="{DynamicResource S.rest.collection}" Foreground="{DynamicResource TextSec}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.newreq}" Click="AddRequest_Click">
                                <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.newfolder}" Click="AddFolder_Click">
                                <ui:SymbolIcon Symbol="FolderAdd24" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.rename}" Click="Rename_Click">
                                <ui:SymbolIcon Symbol="Rename24" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.delete}" Click="DeleteNode_Click">
                                <ui:SymbolIcon Symbol="Delete24" FontSize="16"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <TreeView Grid.Row="1" x:Name="CollTree" BorderThickness="0" Background="Transparent"
                              SelectedItemChanged="Tree_SelectionChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Height="24">
                                    <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="15" Foreground="{Binding IconBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" Margin="7,0,0,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrim}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- Prawy panel: budowniczy żądania + odpowiedź -->
            <Grid Grid.Column="2" Margin="12,10,12,10">
                <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- pasek: metoda + URL + Wyślij/Zapisz -->
                <RowDefinition Height="1.1*" MinHeight="150"/>   <!-- żądanie: zakładki -->
                <RowDefinition Height="Auto"/>   <!-- splitter -->
                <RowDefinition Height="1*" MinHeight="120"/>     <!-- odpowiedź -->
                <RowDefinition Height="Auto"/>   <!-- status -->
            </Grid.RowDefinitions>

            <!-- Pasek żądania -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="MethodCombo" Grid.Column="0" Width="118" FontWeight="SemiBold"
                          SelectionChanged="Method_Changed" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="GET"/>
                    <ComboBoxItem Content="POST"/>
                    <ComboBoxItem Content="PUT"/>
                    <ComboBoxItem Content="PATCH"/>
                    <ComboBoxItem Content="DELETE"/>
                    <ComboBoxItem Content="HEAD"/>
                    <ComboBoxItem Content="OPTIONS"/>
                </ComboBox>
                <ui:TextBox x:Name="UrlBox" Grid.Column="1" Margin="8,0" PlaceholderText="{DynamicResource S.rest.urlph}"
                            VerticalContentAlignment="Center" FontSize="13"/>
                <ui:Button x:Name="SendBtn" Grid.Column="2" Appearance="Primary" Content="{DynamicResource S.rest.send}"
                           MinWidth="104" Click="Send_Click">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Send24"/></ui:Button.Icon>
                </ui:Button>
                <Button x:Name="SaveBtn" Grid.Column="3" Style="{StaticResource RestIconBtn}" Width="34" Height="34" Margin="6,0,0,0"
                        ToolTip="{DynamicResource S.rest.save}" Click="Save_Click">
                    <ui:SymbolIcon Symbol="Save24"/>
                </Button>
            </Grid>

            <!-- Zakładki żądania: Parametry / Nagłówki / Treść / Uwierzytelnianie -->
            <TabControl Grid.Row="1" x:Name="RequestTabs" BorderThickness="0" Background="Transparent" Padding="0,8,0,0">
                <TabItem Header="{DynamicResource S.rest.tab.params}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="0,6,0,4" Margin="2,8,2,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.3*"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="{DynamicResource S.rest.key}" Foreground="{DynamicResource TextTer}" FontSize="11"/>
                                <TextBlock Grid.Column="2" Text="{DynamicResource S.rest.value}" Foreground="{DynamicResource TextTer}" FontSize="11"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ParamsList" ItemTemplate="{StaticResource KvRowTemplate}" Margin="2,2,2,0"/>
                        </ScrollViewer>
                        <Button Grid.Row="2" HorizontalAlignment="Left" Margin="2,6,0,0" Style="{StaticResource RestIconBtn}"
                                Width="Auto" Padding="8,0" Click="AddParam_Click" Foreground="{DynamicResource Accent}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add20" FontSize="14"/>
                                <TextBlock Text="{DynamicResource S.rest.add}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource S.rest.tab.headers}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="0,6,0,4" Margin="2,8,2,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.3*"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="{DynamicResource S.rest.key}" Foreground="{DynamicResource TextTer}" FontSize="11"/>
                                <TextBlock Grid.Column="2" Text="{DynamicResource S.rest.value}" Foreground="{DynamicResource TextTer}" FontSize="11"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="HeadersList" ItemTemplate="{StaticResource KvRowTemplate}" Margin="2,2,2,0"/>
                        </ScrollViewer>
                        <Button Grid.Row="2" HorizontalAlignment="Left" Margin="2,6,0,0" Style="{StaticResource RestIconBtn}"
                                Width="Auto" Padding="8,0" Click="AddHeader_Click" Foreground="{DynamicResource Accent}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add20" FontSize="14"/>
                                <TextBlock Text="{DynamicResource S.rest.add}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource S.rest.tab.body}">
                    <Grid Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,6">
                            <TextBlock Text="{DynamicResource S.rest.body.type}" Foreground="{DynamicResource TextTer}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                            <ComboBox x:Name="ContentTypeCombo" Width="260" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="application/json"/>
                                <ComboBoxItem Content="text/plain"/>
                                <ComboBoxItem Content="application/xml"/>
                                <ComboBoxItem Content="application/x-www-form-urlencoded"/>
                            </ComboBox>
                        </StackPanel>
                        <Border Grid.Row="1" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="6">
                            <TextBox x:Name="BodyBox" BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource TextPrim}" CaretBrush="{DynamicResource TextPrim}"
                                     AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12.5" Padding="8"/>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource S.rest.tab.auth}">
                    <StackPanel Margin="2,10,2,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource S.rest.auth.type}" Foreground="{DynamicResource TextTer}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                            <ComboBox x:Name="AuthCombo" Width="220" SelectionChanged="Auth_Changed" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="{DynamicResource S.rest.auth.none}"/>
                                <ComboBoxItem Content="{DynamicResource S.rest.auth.bearer}"/>
                                <ComboBoxItem Content="{DynamicResource S.rest.auth.basic}"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Bearer -->
                        <StackPanel x:Name="BearerPanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource S.rest.auth.token}" Foreground="{DynamicResource TextTer}" FontSize="12" Margin="0,0,0,3"/>
                            <PasswordBox x:Name="TokenBox" MaxWidth="520" HorizontalAlignment="Left" MinWidth="360"/>
                        </StackPanel>

                        <!-- Basic -->
                        <StackPanel x:Name="BasicPanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource S.rest.auth.user}" Foreground="{DynamicResource TextTer}" FontSize="12" Margin="0,0,0,3"/>
                            <TextBox x:Name="AuthUserBox" Style="{StaticResource RestCell}" MaxWidth="520" MinWidth="360" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource S.rest.auth.pass}" Foreground="{DynamicResource TextTer}" FontSize="12" Margin="0,0,0,3"/>
                            <PasswordBox x:Name="AuthPassBox" MaxWidth="520" MinWidth="360" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <TextBlock x:Name="AuthHint" Text="{DynamicResource S.rest.auth.hint}" Foreground="{DynamicResource TextTer}"
                                   FontSize="11.5" TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- Odpowiedź -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Wiersz statusu odpowiedzi -->
                <Grid Grid.Row="0" Margin="0,4,0,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="StatusPill" CornerRadius="5" Padding="8,2" Visibility="Collapsed">
                            <TextBlock x:Name="StatusPillText" FontWeight="SemiBold" FontSize="12.5" Foreground="White"/>
                        </Border>
                        <TextBlock x:Name="MetaText" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"
                                   Margin="10,0,0,0" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ToggleButton x:Name="PrettyToggle" Content="{DynamicResource S.rest.pretty}" IsChecked="True"
                                      Click="Pretty_Changed" Padding="8,2" FontSize="11.5" Cursor="Hand"/>
                        <Button Style="{StaticResource RestIconBtn}" ToolTip="{DynamicResource S.rest.copy}" Click="CopyBody_Click" Margin="6,0,0,0">
                            <ui:SymbolIcon Symbol="Copy20" FontSize="15"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <TabControl Grid.Row="1" x:Name="ResponseTabs" BorderThickness="0" Background="Transparent">
                    <TabItem Header="{DynamicResource S.rest.resp.body}">
                        <Border BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="6" Margin="0,6,0,0">
                            <TextBox x:Name="ResponseBody" BorderThickness="0" Background="Transparent" IsReadOnly="True"
                                     Foreground="{DynamicResource TextPrim}"
                                     AcceptsReturn="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12.5" Padding="8"
                                     Text="{DynamicResource S.rest.resp.empty}"/>
                        </Border>
                    </TabItem>
                    <TabItem Header="{DynamicResource S.rest.resp.headers}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
                            <ItemsControl x:Name="ResponseHeaders" Margin="2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="{DynamicResource TextSec}"
                                                       FontFamily="Consolas" FontSize="12" Margin="0,0,12,0" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{DynamicResource TextPrim}"
                                                       FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>

            <TextBlock x:Name="StatusText" Grid.Row="4" Foreground="{DynamicResource TextTer}" FontSize="11"
                       Margin="2,6,2,0" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
