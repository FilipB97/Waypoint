<ui:FluentWindow x:Class="RdpManager.ReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource S.update.title}" Width="560" Height="560" MinWidth="460" MinHeight="380"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <Grid Background="{DynamicResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="Bar" Grid.Row="0" Title="{DynamicResource S.update.title}"/>

        <TextBlock x:Name="HeaderText" Grid.Row="1" Margin="20,6,20,10" FontSize="{StaticResource FontTitle}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrim}" TextWrapping="Wrap"/>

        <!-- Notatki wydania (markdown z GitHuba) — renderowane, przewijalne. -->
        <Border Grid.Row="2" Margin="20,0,20,0" Background="{DynamicResource Panel}"
                BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}">
            <FlowDocumentScrollViewer x:Name="NotesView" IsTabStop="False" Padding="0"
                     Foreground="{DynamicResource TextSec}"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
        </Border>

        <StackPanel Grid.Row="3" Margin="{StaticResource DialogButtonRowMargin}">
            <TextBlock x:Name="WarnText" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontBody}" TextWrapping="Wrap"
                       Margin="0,0,0,12" Visibility="Collapsed" Text="{DynamicResource S.update.willrestart}"/>
            <Grid>
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Hyperlink x:Name="GithubLink" Click="Github_Click" Foreground="{DynamicResource Accent}"><Run Text="{DynamicResource S.update.viewgithub}"/></Hyperlink>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button x:Name="CancelBtn" Content="{DynamicResource S.cancel}" Appearance="Secondary" Click="Cancel_Click" Margin="0,0,8,0" MinWidth="96" Visibility="Collapsed" IsCancel="True"/>
                    <ui:Button x:Name="OkBtn" Content="{DynamicResource S.update.now}" Appearance="Primary" Click="Ok_Click" MinWidth="120" IsDefault="True" Visibility="Collapsed"/>
                    <ui:Button x:Name="CloseBtn" Content="{DynamicResource S.m.close}" Appearance="Primary" Click="Close_Click" MinWidth="96" IsDefault="True" Visibility="Collapsed" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
