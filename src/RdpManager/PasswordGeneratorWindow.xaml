<ui:FluentWindow x:Class="RdpManager.PasswordGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource S.gen.title}" Width="440" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource S.gen.title}">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="Key24" Foreground="{DynamicResource Accent}"/></ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="18,8,18,16">
            <!-- wynik -->
            <Border Background="{DynamicResource Elevated}" CornerRadius="{StaticResource RadiusMd}" Padding="12,10" Margin="0,0,0,4">
                <TextBox x:Name="ResultBox" IsReadOnly="True" TextWrapping="Wrap"
                         FontFamily="{DynamicResource Mono}" FontSize="{StaticResource FontSubtitle}" BorderThickness="0"
                         Background="Transparent" Foreground="{DynamicResource TextPrim}"/>
            </Border>
            <TextBlock x:Name="StrengthText" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}" Margin="2,0,0,12"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <ui:Button Content="{DynamicResource S.gen.regenerate}" Appearance="Primary" Click="Generate_Click"/>
                <ui:Button Content="{DynamicResource S.gen.copy}" Appearance="Secondary" Click="Copy_Click" Margin="8,0,0,0"/>
                <TextBlock x:Name="CopiedText" Text="{DynamicResource S.gen.copied}" Foreground="{DynamicResource Online}"
                           VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed"/>
            </StackPanel>

            <!-- typ -->
            <TextBlock Text="{DynamicResource S.gen.type}" Foreground="{DynamicResource TextSec}" Margin="0,0,0,4"/>
            <ComboBox x:Name="TypeCombo" Width="200" HorizontalAlignment="Left" SelectionChanged="Options_Changed">
                <ComboBoxItem Content="{DynamicResource S.gen.type.password}"/>
                <ComboBoxItem Content="{DynamicResource S.gen.type.hex}"/>
                <ComboBoxItem Content="{DynamicResource S.gen.type.guid}"/>
            </ComboBox>

            <!-- opcje hasła -->
            <StackPanel x:Name="PasswordOptions" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource S.gen.length}" Foreground="{DynamicResource TextSec}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="LengthSlider" Minimum="4" Maximum="128" Value="20" Width="220"
                            TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                            ValueChanged="Length_Changed"/>
                    <TextBlock x:Name="LengthText" Text="20" Foreground="{DynamicResource TextPrim}"
                               FontFamily="{DynamicResource Mono}" VerticalAlignment="Center" Margin="10,0,0,0" MinWidth="26"/>
                </StackPanel>
                <WrapPanel Margin="0,10,0,0">
                    <CheckBox x:Name="OptUpper" Content="A-Z" IsChecked="True" Margin="0,0,18,6" Checked="Options_Changed" Unchecked="Options_Changed"/>
                    <CheckBox x:Name="OptLower" Content="a-z" IsChecked="True" Margin="0,0,18,6" Checked="Options_Changed" Unchecked="Options_Changed"/>
                    <CheckBox x:Name="OptDigits" Content="0-9" IsChecked="True" Margin="0,0,18,6" Checked="Options_Changed" Unchecked="Options_Changed"/>
                    <CheckBox x:Name="OptSymbols" Content="!@#$" IsChecked="True" Margin="0,0,18,6" Checked="Options_Changed" Unchecked="Options_Changed"/>
                </WrapPanel>
                <CheckBox x:Name="OptNoAmbiguous" Content="{DynamicResource S.gen.noambiguous}"
                          Foreground="{DynamicResource TextSec}" Checked="Options_Changed" Unchecked="Options_Changed"/>
            </StackPanel>

            <!-- opcje tokenu hex -->
            <StackPanel x:Name="HexOptions" Margin="0,12,0,0" Visibility="Collapsed" Orientation="Horizontal">
                <TextBlock Text="{DynamicResource S.gen.bytes}" Foreground="{DynamicResource TextSec}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Slider x:Name="BytesSlider" Minimum="4" Maximum="64" Value="16" Width="220"
                        TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Options_Changed"/>
                <TextBlock x:Name="BytesText" Text="16" Foreground="{DynamicResource TextPrim}"
                           FontFamily="{DynamicResource Mono}" VerticalAlignment="Center" Margin="10,0,0,0" MinWidth="26"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
