<ui:FluentWindow x:Class="RdpManager.PasswordGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource S.gen.title}" Width="500" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <!-- Segment przełącznika typu (Hasło/Token/GUID) — pigułka, aktywny = tinta akcentu (jak .ttab w mockupie). -->
        <Style x:Key="GenSeg" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="7" Background="Transparent" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSoft}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ikona-przycisk (kopiuj/odśwież) w polu wyniku — subtelny hover. -->
        <Style x:Key="IconGhostBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="8" Background="{DynamicResource Accent}" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.12"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.20"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Wiersz opcji: etykieta z lewej + kontrolka z prawej, hairline na dole. -->
        <Style x:Key="OptRow" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="MinHeight" Value="44"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource S.gen.title}">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="Key24" Foreground="{DynamicResource Accent}"/></ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Karta narzędzia (.toolcard) -->
        <Border Grid.Row="1" Margin="18,4,18,18" Background="{DynamicResource Panel}"
                BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="16" Padding="20,18">
            <StackPanel>
                <TextBlock Text="{DynamicResource S.gen.heading}" Foreground="{DynamicResource TextPrim}"
                           FontSize="{StaticResource FontSubtitle}" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <!-- Segmentowany wybór typu -->
                <Border Background="{DynamicResource Elevated}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        CornerRadius="10" Padding="3" Margin="0,0,0,18">
                    <UniformGrid Rows="1" Columns="3">
                        <RadioButton x:Name="SegPassword" GroupName="GenType" Style="{StaticResource GenSeg}" Checked="Type_Changed">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Password24" FontSize="{StaticResource IconSm}" Margin="0,0,7,0"/>
                                <TextBlock Text="{DynamicResource S.gen.type.password}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="SegHex" GroupName="GenType" Style="{StaticResource GenSeg}" Checked="Type_Changed">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Key24" FontSize="{StaticResource IconSm}" Margin="0,0,7,0"/>
                                <TextBlock Text="{DynamicResource S.gen.type.hex}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="SegGuid" GroupName="GenType" Style="{StaticResource GenSeg}" Checked="Type_Changed">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Fingerprint24" FontSize="{StaticResource IconSm}" Margin="0,0,7,0"/>
                                <TextBlock Text="{DynamicResource S.gen.type.guid}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </UniformGrid>
                </Border>

                <!-- Pole wyniku z ikonami kopiuj/odśwież (.secretbox) -->
                <Border Background="{DynamicResource Elevated}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        CornerRadius="11" MinHeight="56" Padding="16,0,8,0" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ResultBox" Grid.Column="0" IsReadOnly="True" TextWrapping="Wrap"
                                 FontFamily="{DynamicResource Mono}" FontSize="{StaticResource FontSubtitle}" BorderThickness="0"
                                 Background="Transparent" Foreground="{DynamicResource TextPrim}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource IconGhostBtn}" Click="Copy_Click"
                                ToolTip="{DynamicResource S.gen.copy}" AutomationProperties.Name="{DynamicResource S.gen.copy}">
                            <ui:SymbolIcon Symbol="Copy24" FontSize="{StaticResource IconMd}"/>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource IconGhostBtn}" Click="Generate_Click"
                                ToolTip="{DynamicResource S.gen.regenerate}" AutomationProperties.Name="{DynamicResource S.gen.regenerate}">
                            <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="{StaticResource IconMd}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Pasek siły (4 segmenty) + etykieta -->
                <UniformGrid Rows="1" Columns="4" Height="5" Margin="0,0,0,7">
                    <Border x:Name="Sb1" CornerRadius="2" Background="{DynamicResource Elevated}" Margin="0,0,5,0"/>
                    <Border x:Name="Sb2" CornerRadius="2" Background="{DynamicResource Elevated}" Margin="0,0,5,0"/>
                    <Border x:Name="Sb3" CornerRadius="2" Background="{DynamicResource Elevated}" Margin="0,0,5,0"/>
                    <Border x:Name="Sb4" CornerRadius="2" Background="{DynamicResource Elevated}"/>
                </UniformGrid>
                <TextBlock x:Name="StrengthText" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}"
                           FontWeight="SemiBold" Margin="0,0,0,14"/>

                <!-- Opcje hasła -->
                <StackPanel x:Name="PasswordOptions">
                    <Border Style="{StaticResource OptRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.gen.length}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                            <Slider x:Name="LengthSlider" Grid.Column="1" Minimum="4" Maximum="128" Value="20" Margin="16,0,12,0"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Length_Changed"/>
                            <TextBlock x:Name="LengthText" Grid.Column="2" Text="20" Foreground="{DynamicResource TextPrim}"
                                       FontFamily="{DynamicResource Mono}" FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="26" TextAlignment="Right"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource OptRow}">
                        <Grid>
                            <TextBlock Text="{DynamicResource S.gen.opt.upper}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch x:Name="OptUpper" IsChecked="True" HorizontalAlignment="Right" Checked="Options_Changed" Unchecked="Options_Changed"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource OptRow}">
                        <Grid>
                            <TextBlock Text="{DynamicResource S.gen.opt.lower}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch x:Name="OptLower" IsChecked="True" HorizontalAlignment="Right" Checked="Options_Changed" Unchecked="Options_Changed"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource OptRow}">
                        <Grid>
                            <TextBlock Text="{DynamicResource S.gen.opt.digits}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch x:Name="OptDigits" IsChecked="True" HorizontalAlignment="Right" Checked="Options_Changed" Unchecked="Options_Changed"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource OptRow}">
                        <Grid>
                            <TextBlock Text="{DynamicResource S.gen.opt.symbols}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch x:Name="OptSymbols" IsChecked="True" HorizontalAlignment="Right" Checked="Options_Changed" Unchecked="Options_Changed"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource OptRow}" BorderThickness="0">
                        <Grid>
                            <TextBlock Text="{DynamicResource S.gen.noambiguous}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch x:Name="OptNoAmbiguous" HorizontalAlignment="Right" Checked="Options_Changed" Unchecked="Options_Changed"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Opcje tokenu hex -->
                <StackPanel x:Name="HexOptions" Visibility="Collapsed">
                    <Border Style="{StaticResource OptRow}" BorderThickness="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.gen.bytes}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                            <Slider x:Name="BytesSlider" Grid.Column="1" Minimum="4" Maximum="64" Value="16" Margin="16,0,12,0"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Options_Changed"/>
                            <TextBlock x:Name="BytesText" Grid.Column="2" Text="16" Foreground="{DynamicResource TextPrim}"
                                       FontFamily="{DynamicResource Mono}" FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="26" TextAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <TextBlock x:Name="CopiedText" Text="{DynamicResource S.gen.copied}" Foreground="{DynamicResource Online}"
                           FontSize="{StaticResource FontSmall}" Margin="2,12,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
