<ui:FluentWindow x:Class="RdpManager.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource S.nav.about}" Width="440" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource S.nav.about}"/>

        <StackPanel Grid.Row="1" Margin="24,8,24,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Image Source="pack://application:,,,/Assets/app.ico" Width="52" Height="52"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="Waypoint" FontSize="{StaticResource FontDisplay}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrim}"/>
                    <TextBlock x:Name="VersionText" Foreground="{DynamicResource TextSec}" FontSize="{StaticResource FontBody}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="{DynamicResource S.msg.about.desc}" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSec}" Margin="0,0,0,16"/>

            <TextBlock Foreground="{DynamicResource TextSec}">
                <Run Text="{DynamicResource S.about.author}"/><Hyperlink Click="Author_Click" Foreground="{DynamicResource Accent}" ToolTip="https://github.com/FilipB97"><Run Text="Filip Benklewski" FontWeight="SemiBold"/></Hyperlink>
            </TextBlock>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <ui:Button Content="{DynamicResource S.about.repo}" Appearance="Secondary" Click="Repo_Click"/>
            </StackPanel>

            <TextBlock x:Name="DataPathText" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}"
                       FontFamily="{DynamicResource Mono}" TextWrapping="Wrap" Margin="0,16,0,0"/>

            <ui:Button Content="{DynamicResource S.m.close}" Appearance="Primary" HorizontalAlignment="Right"
                       Margin="0,18,0,0" MinWidth="96" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
