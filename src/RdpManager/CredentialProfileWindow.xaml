<ui:FluentWindow x:Class="RdpManager.CredentialProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource S.prof.edit.title}" Width="400" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource S.prof.edit.title}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="{StaticResource DialogContentMargin}">
            <TextBlock Text="{DynamicResource S.prof.name}" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="NameBox"/>

            <TextBlock Text="{DynamicResource S.cp.domainopt}" Margin="0,10,0,4"/>
            <ui:TextBox x:Name="DomainBox"/>

            <TextBlock Text="{DynamicResource S.se.user}" Margin="0,10,0,4"/>
            <ui:TextBox x:Name="UserBox"/>

            <TextBlock Text="{DynamicResource S.pass}" Margin="0,10,0,4"/>
            <PasswordBox x:Name="PassBox" VerticalContentAlignment="Center"/>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogButtonRowMargin}">
            <ui:Button Content="{DynamicResource S.cancel}" Appearance="Secondary" Click="Cancel_Click" Margin="0,0,8,0" MinWidth="90" IsCancel="True"/>
            <ui:Button Content="{DynamicResource S.save}" Appearance="Primary" Click="Ok_Click" MinWidth="90" IsDefault="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
