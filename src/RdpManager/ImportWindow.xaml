<ui:FluentWindow x:Class="RdpManager.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource S.import.title}" Width="600" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <!-- Nagłówek grupy źródeł (.srchdr) -->
        <Style x:Key="SrcHdr" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextTer}"/>
            <Setter Property="FontSize" Value="{StaticResource FontMicro}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4,12,0,7"/>
        </Style>

        <!-- Karta źródła (.srccard): obrys, hover, ikona + nazwa + opis -->
        <Style x:Key="SrcCard" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                CornerRadius="12" Background="Transparent" Padding="12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Elevated}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <!-- Tło = CanvasBrush (jak treść głównego okna), spójne z motywem/presetem — nie systemowa Mica. -->
    <Grid Background="{DynamicResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource S.import.title}">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="ArrowImport24" Foreground="{DynamicResource Accent}"/></ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="18,2,18,16">
            <TextBlock Text="{DynamicResource S.import.title}" Foreground="{DynamicResource TextPrim}"
                       FontSize="{StaticResource FontSubtitle}" FontWeight="SemiBold" Margin="4,0,0,4"/>
            <TextBlock Text="{DynamicResource S.import.sub}" Foreground="{DynamicResource TextSec}"
                       FontSize="{StaticResource FontSmall}" TextWrapping="Wrap" Margin="4,0,0,8"/>

            <TextBlock Text="{DynamicResource S.import.hdr.remote}" Style="{StaticResource SrcHdr}"/>
            <UniformGrid Columns="2">
                <Button Style="{StaticResource SrcCard}" Tag="mstsc" Click="Card_Click">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Background="{DynamicResource Elevated}" Margin="0,0,11,0">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource Accent}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource S.import.name.mstsc}" Foreground="{DynamicResource TextPrim}" FontWeight="SemiBold" FontSize="{StaticResource FontBody}"/>
                            <TextBlock Text="{DynamicResource S.import.desc.mstsc}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SrcCard}" Tag="rdp" Click="Card_Click">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Background="{DynamicResource Elevated}" Margin="0,0,11,0">
                            <ui:SymbolIcon Symbol="Document24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource Accent}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource S.import.name.rdp}" Foreground="{DynamicResource TextPrim}" FontWeight="SemiBold" FontSize="{StaticResource FontBody}"/>
                            <TextBlock Text="{DynamicResource S.import.desc.rdp}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SrcCard}" Tag="mrng" Click="Card_Click">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Background="{DynamicResource Elevated}" Margin="0,0,11,0">
                            <ui:SymbolIcon Symbol="Server24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource Accent}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource S.import.name.mrng}" Foreground="{DynamicResource TextPrim}" FontWeight="SemiBold" FontSize="{StaticResource FontBody}"/>
                            <TextBlock Text="{DynamicResource S.import.desc.mrng}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SrcCard}" Tag="rdcman" Click="Card_Click">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Background="{DynamicResource Elevated}" Margin="0,0,11,0">
                            <ui:SymbolIcon Symbol="ServerMultiple20" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource Accent}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource S.import.name.rdcman}" Foreground="{DynamicResource TextPrim}" FontWeight="SemiBold" FontSize="{StaticResource FontBody}"/>
                            <TextBlock Text="{DynamicResource S.import.desc.rdcman}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SrcCard}" Tag="rdm" Click="Card_Click">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Background="{DynamicResource Elevated}" Margin="0,0,11,0">
                            <ui:SymbolIcon Symbol="Apps24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource Accent}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource S.import.name.rdm}" Foreground="{DynamicResource TextPrim}" FontWeight="SemiBold" FontSize="{StaticResource FontBody}"/>
                            <TextBlock Text="{DynamicResource S.import.desc.rdm}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </UniformGrid>

            <TextBlock Text="{DynamicResource S.import.hdr.files}" Style="{StaticResource SrcHdr}"/>
            <UniformGrid Columns="2">
                <Button Style="{StaticResource SrcCard}" Tag="filezilla" Click="Card_Click">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Background="{DynamicResource Elevated}" Margin="0,0,11,0">
                            <ui:SymbolIcon Symbol="FolderPeople24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource Accent}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource S.import.name.filezilla}" Foreground="{DynamicResource TextPrim}" FontWeight="SemiBold" FontSize="{StaticResource FontBody}"/>
                            <TextBlock Text="{DynamicResource S.import.desc.filezilla}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </UniformGrid>

            <TextBlock Text="{DynamicResource S.import.hdr.rest}" Style="{StaticResource SrcHdr}"/>
            <UniformGrid Columns="2">
                <Button Style="{StaticResource SrcCard}" Tag="postman" Click="Card_Click">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Background="{DynamicResource Elevated}" Margin="0,0,11,0">
                            <ui:SymbolIcon Symbol="Globe24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource Accent}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource S.import.name.postman}" Foreground="{DynamicResource TextPrim}" FontWeight="SemiBold" FontSize="{StaticResource FontBody}"/>
                            <TextBlock Text="{DynamicResource S.import.desc.postman}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </UniformGrid>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
