<ui:FluentWindow x:Class="RdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="Waypoint" Width="1180" Height="720" MinWidth="900" MinHeight="560"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Loaded="Window_Loaded" KeyDown="Window_KeyDown" PreviewMouseWheel="Window_PreviewMouseWheel" Closing="Window_Closing" StateChanged="Window_StateChanged">

    <Window.Resources>
        <!-- Kolory / pędzle / gradienty / font żyją w Themes/Palette.{Dark,Light}.xaml
             (na poziomie App, przełączane w runtime przez ThemeManager). Tu tylko style. -->

        <!-- Rail button (icon) -->
        <Style x:Key="RailBtn" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTer}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusMd}"
                                    BorderThickness="2" BorderBrush="Transparent"/>
                            <Border x:Name="HoverFill" CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource RailHover}" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RailBtnActive" TargetType="Button" BasedOn="{StaticResource RailBtn}">
            <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
        </Style>

        <!-- 28x28 icon button (status bar) -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="3,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}"
                                    BorderThickness="2" BorderBrush="Transparent"/>
                            <Border x:Name="HoverFill" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource Elevated}" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="CardHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{StaticResource FontBodyLg}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ===== Ustawienia w stylu mockupu Compass: nagłówek kategorii + podtytuł, pod-sekcje,
             wiersze dwukolumnowe (etykieta z lewej / kontrolka z prawej), kontrolki segmentowe. ===== -->
        <Style x:Key="SetPageHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="{StaticResource FontTitle}"/>
        </Style>
        <Style x:Key="SetPageSub" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
            <Setter Property="Margin" Value="0,5,0,20"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- Pod-sekcja (WYGLĄD / LISTA SERWERÓW …) -->
        <Style x:Key="SetSec" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextTer}"/>
            <Setter Property="FontSize" Value="{StaticResource FontCaption}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,18,0,2"/>
        </Style>
        <!-- Wiersz ustawienia: cienki dzielnik u dołu, wyśrodkowanie w pionie -->
        <Style x:Key="SetRow" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,11"/>
            <Setter Property="MinHeight" Value="46"/>
        </Style>
        <Style x:Key="SetLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
            <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SetSub" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextTer}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSmall}"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <!-- Kontener kontrolki segmentowej (pasek pigułek) -->
        <Style x:Key="SegBar" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Elevated}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Segment (RadioButton jako pigułka); zaznaczony = tło akcentu + tekst akcentu -->
        <Style x:Key="Seg" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSmall}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" CornerRadius="{StaticResource RadiusSm}" Background="Transparent" Height="28" Padding="13,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentSoft}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="AppTitleBar" Grid.Row="0" Height="32" Title="Waypoint">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Desktop24" Foreground="{DynamicResource Accent}"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- BODY (skalowane zoomem Ctrl+kółko; titlebar zostaje 1:1) -->
        <Grid x:Name="BodyGrid" Grid.Row="1">
            <Grid.LayoutTransform>
                <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
            </Grid.LayoutTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- RAIL -->
            <Border x:Name="Rail" Grid.Column="0" Width="52" Background="{DynamicResource RailBg}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
                <Grid Margin="0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                        <Button x:Name="NavDashboard" Style="{DynamicResource RailBtn}" ToolTip="{DynamicResource S.nav.dashboard}" AutomationProperties.Name="{DynamicResource S.nav.dashboard}" Tag="Dashboard" Click="Nav_Click">
                            <ui:SymbolIcon x:Name="IcoDashboard" Symbol="Apps24" FontSize="{StaticResource IconLg}" Foreground="{DynamicResource TextTer}"/>
                        </Button>
                        <Button x:Name="NavSessions" Style="{DynamicResource RailBtn}" ToolTip="{DynamicResource S.nav.sessions}" AutomationProperties.Name="{DynamicResource S.nav.sessions}" Tag="Sessions" Click="Nav_Click">
                            <ui:SymbolIcon x:Name="IcoSessions" Symbol="Desktop24" FontSize="{StaticResource IconLg}" Foreground="{DynamicResource TextTer}"/>
                        </Button>
                        <Button x:Name="NavRecent" Style="{DynamicResource RailBtn}" ToolTip="{DynamicResource S.nav.recent}" AutomationProperties.Name="{DynamicResource S.nav.recent}" Tag="Recent" Click="Nav_Click">
                            <ui:SymbolIcon x:Name="IcoRecent" Symbol="History24" FontSize="{StaticResource IconLg}" Foreground="{DynamicResource TextTer}"/>
                        </Button>
                        <Button x:Name="NavRest" Style="{DynamicResource RailBtn}" ToolTip="{DynamicResource S.nav.rest}" AutomationProperties.Name="{DynamicResource S.nav.rest}" Click="NavRest_Click">
                            <ui:SymbolIcon x:Name="IcoRest" Symbol="Braces24" FontSize="{StaticResource IconLg}" Foreground="{DynamicResource TextTer}"/>
                        </Button>
                        <Button x:Name="NavTools" Style="{DynamicResource RailBtn}" ToolTip="{DynamicResource S.nav.tools}" AutomationProperties.Name="{DynamicResource S.nav.tools}" Click="OpenPasswordGen_Click">
                            <ui:SymbolIcon x:Name="IcoTools" Symbol="Key24" FontSize="{StaticResource IconLg}" Foreground="{DynamicResource TextTer}"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                        <Button x:Name="NavImport" Style="{DynamicResource RailBtn}" ToolTip="{DynamicResource S.import}" AutomationProperties.Name="{DynamicResource S.import}" Click="OpenImport_Click">
                            <ui:SymbolIcon Symbol="ArrowImport24" FontSize="{StaticResource IconLg}" Foreground="{DynamicResource TextTer}"/>
                        </Button>
                        <!-- „O aplikacji" przeniesione do Ustawień (Compass §4.6) — usunięte z raila. -->
                        <Button x:Name="NavSettings" Style="{DynamicResource RailBtn}" ToolTip="{DynamicResource S.nav.settings}" AutomationProperties.Name="{DynamicResource S.nav.settings}" Tag="Settings" Click="Nav_Click">
                            <ui:SymbolIcon x:Name="IcoSettings" Symbol="Settings24" FontSize="{StaticResource IconLg}" Foreground="{DynamicResource TextTer}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SIDEBAR -->
            <!-- Tło paska bocznego = RailBg (jak rail i pasek kart) — spójne z chromem, nie odstaje jak jasny Panel. -->
            <Border x:Name="Sidebar" Grid.Column="1" Width="228" Background="{DynamicResource RailBg}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ui:TextBox x:Name="SearchBox" Grid.Row="0" Margin="12,12,12,8" PlaceholderText="{DynamicResource S.search}"
                                TextChanged="SearchBox_TextChanged">
                        <ui:TextBox.Icon>
                            <ui:SymbolIcon Symbol="Search24"/>
                        </ui:TextBox.Icon>
                    </ui:TextBox>

                    <!-- Chipy filtra protokołów (Compass §4.2) — budowane w kodzie z protokołów obecnych na liście;
                         ukryte, gdy jest tylko jeden protokół (nie ma czego filtrować). -->
                    <WrapPanel x:Name="ProtoFilterBar" Grid.Row="1" Orientation="Horizontal" Margin="12,0,8,4" Visibility="Collapsed"/>

                    <ScrollViewer x:Name="ServerScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="8,0">
                        <AdornerDecorator>
                            <StackPanel x:Name="ServerTree"/>
                        </AdornerDecorator>
                    </ScrollViewer>

                    <TextBlock x:Name="TreeEmptyHint" Grid.Row="2" Visibility="Collapsed" Text=""
                               Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontBody}" TextWrapping="Wrap" TextAlignment="Center"
                               VerticalAlignment="Top" HorizontalAlignment="Center" Margin="20,32,20,0"/>

                    <!-- Moduł REST (Compass §4.4): rail „REST" przełącza sidebar na drzewo kolekcji. Nakłada się na
                         rzędy 0–2 (wyszukiwarka/chipy/drzewo serwerów są chowane, gdy aktywny). -->
                    <Grid x:Name="RestModule" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="14,14,14,8">
                            <TextBlock Text="{DynamicResource S.rest.collection}" Foreground="{DynamicResource TextTer}"
                                       FontWeight="Bold" FontSize="{StaticResource FontCaption}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RestModuleCount" HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextTer}" FontFamily="{DynamicResource Mono}" FontSize="{StaticResource FontCaption}"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,0">
                            <StackPanel x:Name="RestModuleTree"/>
                        </ScrollViewer>
                    </Grid>

                    <Border Grid.Row="3" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="10">
                        <StackPanel>
                            <!-- Nieblokujący sygnał samonaprawy konfiguracji (przywrócenie z kopii / kwarantanna
                                 uszkodzonego pliku). Pokazywany raz na starcie, gdy HealthNotices coś zebrało;
                                 w stopce panelu — zawsze WPF, poza airspace kontrolki RDP. Domyślnie zwinięty. -->
                            <ui:InfoBar x:Name="HealthInfoBar" IsOpen="False" IsClosable="True" Margin="0,0,0,6"/>
                            <!-- Pojawia się tylko, gdy CheckForUpdatesAsync znajdzie nowszą wersję. -->
                            <ui:Button x:Name="UpdateBtn" Visibility="Collapsed" HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Stretch"
                                       Appearance="Info" Margin="0,0,0,6" Click="Update_Click">
                                <ui:Button.ContentTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </DataTemplate>
                                </ui:Button.ContentTemplate>
                            </ui:Button>
                            <ui:Button Content="{DynamicResource S.quickConnect}" HorizontalAlignment="Stretch"
                                       Appearance="Primary" Click="QuickConnect_Click"
                                       ToolTip="{DynamicResource S.quickConnect.tip}"/>
                            <ui:Button Content="{DynamicResource S.addServer}" HorizontalAlignment="Stretch"
                                       Appearance="Secondary" Margin="0,6,0,0" Click="AddServer_Click"/>
                            <!-- Import: otwiera modal z kartami źródeł (mstsc/.rdp/mRemoteNG/RDCMan/RDM/FileZilla/Postman). -->
                            <ui:Button Content="{DynamicResource S.import}" HorizontalAlignment="Stretch"
                                       Appearance="Secondary" Margin="0,6,0,0" Click="OpenImport_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN (przełączane widoki: Sesje / Pulpit / Ostatnie / Ustawienia) -->
            <Grid Grid.Column="2">
            <Grid x:Name="SessionsView">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Strefa „hot zone" pod paskiem tylko dla kotwicy paska pełnoekranowego (Popup).
                         W oknie 0 (żeby nie było odstępu pod kartami); w pełnym ekranie i tak jest 0. -->
                    <RowDefinition x:Name="SessionHotZoneRow" Height="0"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- tab strip (built in code) -->
                <!-- CaptionHeight=0 (tak WPF-UI tworzy WindowChrome — potwierdzone logiem), więc CAŁA góra okna
                     to obszar klienta i pasek kart NIE potrzebuje IsHitTestVisibleInChrome (karty i tak łapią się
                     zwykłym hit-testem). Ten atrybut wręcz PSUŁ hover ikon w skupieniu: klik działał (HTCLIENT),
                     ale WPF nie aktualizował IsMouseOver dla elementów w strefie „chrome" (znany bug WPF) — więc
                     ikony nie podświetlały się po ponownym włączeniu skupienia. Zdjęty stąd i z przycisków. -->
                <Border x:Name="TabStripHost" Grid.Row="0"
                        Background="{DynamicResource RailBg}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Pasek przewijania ukryty: przy wielu kartach przewija się kółkiem myszy (handler niżej)
                             i przeciąganiem — bez brzydkiego natywnego scrollbara pod kartami. -->
                        <ScrollViewer x:Name="TabScroller" Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="TabScroller_PreviewMouseWheel">
                            <StackPanel x:Name="TabStrip" Orientation="Horizontal" Margin="8,6,8,6"/>
                        </ScrollViewer>
                        <!-- Tryb skupienia (zmaksymalizowane): titlebar + pasek stanu znikają, więc pełny ekran
                             i przyciski okna (minimalizuj / przywróć / zamknij) mieszkają tu, na pasku kart. -->
                        <!-- Przyciski BEZ IsHitTestVisibleInChrome (patrz komentarz wyżej): przy CaptionHeight=0
                             działają zwykłym hit-testem WPF, z poprawnym hover/IsMouseOver. -->
                        <StackPanel x:Name="FocusControls" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="4,0,6,0" Visibility="Collapsed">
                            <Button x:Name="QuickSwitchBtn" Style="{DynamicResource IconBtn}" Click="QuickSwitch_Click"
                                    ToolTip="{DynamicResource S.qs.tip}">
                                <ui:SymbolIcon Symbol="Add24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextTer}"/>
                            </Button>
                            <Button Style="{DynamicResource IconBtn}" Click="ToggleFocus_Click"
                                    ToolTip="{DynamicResource S.focus.toggle}">
                                <TextBlock Text="&#x25A3;" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextTer}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{DynamicResource IconBtn}" Click="Fullscreen_Click"
                                    ToolTip="{DynamicResource S.tip.fullscreen}">
                                <ui:SymbolIcon Symbol="FullScreenMaximize24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextTer}"/>
                            </Button>
                            <Button Style="{DynamicResource IconBtn}" Click="FocusMinimize_Click"
                                    ToolTip="{DynamicResource S.tip.minimize}">
                                <TextBlock Text="&#x2212;" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{DynamicResource IconBtn}" Click="FocusRestore_Click"
                                    ToolTip="{DynamicResource S.fs.restore}">
                                <TextBlock Text="&#x2750;" FontSize="{StaticResource IconSm}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{DynamicResource IconBtn}" Click="FocusClose_Click"
                                    ToolTip="{DynamicResource S.m.close}">
                                <TextBlock Text="&#x2715;" FontSize="{StaticResource IconSm}" Foreground="{DynamicResource Danger}" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                        <!-- Połączona sesja (poza trybem skupienia): akcje przy prawym końcu paska kart —
                             zamiast osobnego paska stanu. Widoczne tylko gdy okno NIE jest w trybie skupienia,
                             więc pasek kart nie leży w strefie caption i nie trzeba tu IsHitTestVisibleInChrome. -->
                        <StackPanel x:Name="SessionActions" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="4,0,6,0" Visibility="Collapsed">
                            <Button x:Name="FilesBtn" Style="{DynamicResource IconBtn}" Click="Files_Click"
                                    Visibility="Collapsed" ToolTip="{DynamicResource S.sftp.toggle}">
                                <ui:SymbolIcon Symbol="Folder24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextTer}"/>
                            </Button>
                            <Button x:Name="CadBtn" Style="{DynamicResource IconBtn}" Click="SendCtrlAltDel_Click"
                                    Visibility="Collapsed" ToolTip="{DynamicResource S.tip.cad}">
                                <ui:SymbolIcon Symbol="Keyboard24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextTer}"/>
                            </Button>
                            <Button Style="{DynamicResource IconBtn}" Click="ToggleFocus_Click" ToolTip="{DynamicResource S.focus.toggle}">
                                <TextBlock Text="&#x25A3;" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextTer}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{DynamicResource IconBtn}" Click="Fullscreen_Click" ToolTip="{DynamicResource S.tip.fullscreen}">
                                <ui:SymbolIcon Symbol="FullScreenMaximize24" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextTer}"/>
                            </Button>
                            <Button Style="{DynamicResource IconBtn}" Click="Disconnect_Click" ToolTip="{DynamicResource S.disconnect}">
                                <TextBlock Text="✕" FontSize="{StaticResource IconSm}" Foreground="{DynamicResource Danger}"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- session toolbar: two states -->
                <Border x:Name="SessionToolbar" Grid.Row="1" Background="{DynamicResource Panel}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="12,5">
                    <Grid>
                        <!-- disconnected -> kompaktowy pasek połączenia (pełna edycja jest w oknie serwera) -->
                        <StackPanel x:Name="ConnectForm" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CfAvatar" Width="18" Height="18" CornerRadius="{StaticResource RadiusSm}" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock x:Name="CfAvatarText" Foreground="{DynamicResource TextOnColor}" FontSize="{StaticResource FontMicro}" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="CfName" Foreground="{DynamicResource TextPrim}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CfHost" FontFamily="{DynamicResource Mono}" Foreground="{DynamicResource TextTer}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <CheckBox x:Name="WinAuthCheck" Content="{DynamicResource S.winauth}" Foreground="{DynamicResource TextSec}"
                                      VerticalAlignment="Center" Margin="16,0,0,0" Checked="WinAuth_Changed" Unchecked="WinAuth_Changed"/>
                            <StackPanel x:Name="CfPassGroup" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="{DynamicResource S.pass}" Style="{DynamicResource FieldLabel}"/>
                                <PasswordBox x:Name="PassBox" Width="150" VerticalContentAlignment="Center" KeyDown="PassBox_KeyDown"/>
                            </StackPanel>
                            <ui:Button x:Name="ConnectBtn" Content="{DynamicResource S.connect}" Appearance="Primary" Click="Connect_Click" Margin="16,0,0,0"/>
                            <Ellipse x:Name="CfStatusDot" Width="7" Height="7" Fill="{DynamicResource TextTer}"
                                     VerticalAlignment="Center" Margin="14,0,6,0" Visibility="Collapsed"/>
                            <TextBlock x:Name="StatusText" Text="—" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"
                                       MaxWidth="460" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                    </Grid>
                </Border>

                <Border x:Name="HotZone" Grid.Row="2" Background="Transparent"/>

                <!-- all sessions' hosts live here; only the active one is Visible -->
                <!-- Kontr-transformacja skali UI: zoom Waypointa NIE powiększa widoku sesji (RDP/terminal/VNC).
                     SessionScale = 1/UiScale znosi RootScale, więc host renderuje 1:1 i rozdzielczość liczona
                     z ActualWidth odpowiada realnym pikselom (bez tego serwer był większy niż okno przy <100%). -->
                <Grid x:Name="SessionContainer" Grid.Row="3" Background="{DynamicResource CanvasBrush}">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="SessionScale" ScaleX="1" ScaleY="1"/>
                    </Grid.LayoutTransform>
                    <!-- Podział ekranu (split-screen): kol.0 = lewy panel, kol.1 = GridSplitter, kol.2 = prawy panel.
                         Bez podziału: splitter zwinięty i kol.2=0, więc hosty sesji (Grid.Column domyślnie 0) wypełniają
                         kol.0 = pełną szerokość — zachowanie bez zmian. W podziale kol.2 dostaje "*". -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="PaneColLeft" Width="*"/>
                        <ColumnDefinition x:Name="PaneColSplit" Width="Auto"/>
                        <ColumnDefinition x:Name="PaneColRight" Width="0"/>
                    </Grid.ColumnDefinitions>
                    <!-- Pusty stan (brak aktywnej sesji): znak Waypoint + szybkie łączenie + ostatnie + skróty (Compass §3).
                         Leży w SessionContainer, ale gdy pusto nie ma tu kontrolki RDP, więc airspace nie przeszkadza. -->
                    <StackPanel x:Name="EmptyState" Grid.ColumnSpan="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                                MaxWidth="480" Margin="24">
                        <Border Width="60" Height="60" CornerRadius="{StaticResource RadiusLg}" Background="{DynamicResource LogoBrush}"
                                HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="30" Foreground="{DynamicResource TextOnColor}"/>
                        </Border>
                        <TextBlock Text="{DynamicResource S.empty.title}" Foreground="{DynamicResource TextPrim}"
                                   FontSize="{StaticResource FontSubtitle}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        <TextBlock Text="{DynamicResource S.emptyhint}" Foreground="{DynamicResource TextSec}"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>

                        <!-- Szybkie połączenie: host · user@host · host:port -->
                        <Grid Width="380" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="EmptyQuickBox" Grid.Column="0" PlaceholderText="{DynamicResource S.empty.quick.placeholder}"
                                        KeyDown="EmptyQuick_KeyDown">
                                <ui:TextBox.Icon><ui:SymbolIcon Symbol="Flash24"/></ui:TextBox.Icon>
                            </ui:TextBox>
                            <ui:Button Grid.Column="1" Content="{DynamicResource S.connect}" Appearance="Primary" Margin="8,0,0,0"
                                       Click="EmptyQuick_Click"/>
                        </Grid>

                        <!-- Ostatnie połączenia (chipy) -->
                        <TextBlock x:Name="EmptyRecentLabel" Text="{DynamicResource S.empty.recent}" Foreground="{DynamicResource TextTer}"
                                   FontSize="{StaticResource FontCaption}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,22,0,8"/>
                        <WrapPanel x:Name="EmptyRecentChips" HorizontalAlignment="Center" MaxWidth="440"/>

                        <TextBlock Text="{DynamicResource S.empty.shortcuts}" Foreground="{DynamicResource TextTer}"
                                   FontSize="{StaticResource FontSmall}" HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,22,0,0"/>
                    </StackPanel>

                    <!-- Uchwyt podziału między panelami (leży w nieprzykrytej kol.1 → działa mimo airspace hostów). -->
                    <GridSplitter x:Name="PaneSplitter" Grid.Column="1" Width="6" Visibility="Collapsed"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext" Background="{DynamicResource Border}"/>

                    <!-- Stan sesji gdy kontrolka RDP jest schowana (łączenie / rozłączono) -->
                    <Border x:Name="SessionOverlay" Grid.ColumnSpan="3" Visibility="Collapsed" Background="{DynamicResource CanvasBrush}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460">
                            <ui:ProgressRing x:Name="OverlaySpinner" IsIndeterminate="True" Width="46" Height="46"
                                             Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                            <TextBlock x:Name="OverlayTitle" Foreground="{DynamicResource TextPrim}" FontSize="{StaticResource FontSubtitle}"
                                       FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="OverlayMsg" Foreground="{DynamicResource TextSec}" HorizontalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            <ui:Button x:Name="OverlayReconnect" Content="{DynamicResource S.reconnect}" Appearance="Primary"
                                       Click="OverlayAction_Click" HorizontalAlignment="Center" Margin="0,18,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
            <!-- /SessionsView -->

            <!-- Pulpit -->
            <ScrollViewer x:Name="DashboardView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Background="{DynamicResource CanvasBrush}">
                <StackPanel Margin="28,24">
                    <TextBlock Text="{DynamicResource S.nav.dashboard}" Foreground="{DynamicResource TextPrim}" FontSize="{StaticResource FontHeading}" FontWeight="SemiBold" Margin="0,0,0,18"/>
                    <StackPanel x:Name="DashboardPanel"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Ostatnie -->
            <ScrollViewer x:Name="RecentView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Background="{DynamicResource CanvasBrush}">
                <StackPanel Margin="28,24">
                    <TextBlock Text="{DynamicResource S.view.recent}" Foreground="{DynamicResource TextPrim}" FontSize="{StaticResource FontHeading}" FontWeight="SemiBold" Margin="0,0,0,18"/>
                    <StackPanel x:Name="RecentPanel"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Ustawienia -->
            <Grid x:Name="SettingsView" Visibility="Collapsed" Background="{DynamicResource CanvasBrush}">
                <Grid.Resources>
                    <!-- Pozycja lewej nawigacji Ustawień: przezroczysta; hover/zaznaczenie = tło Panel + pasek akcentu. -->
                    <Style x:Key="SettingsNavItem" TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
                        <Setter Property="Margin" Value="0,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid>
                                        <Border x:Name="Bd" CornerRadius="{StaticResource RadiusSm}" Background="Transparent"
                                                BorderThickness="2" BorderBrush="Transparent"/>
                                        <Border x:Name="HoverFill" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource Panel}" Opacity="0"/>
                                        <Grid Margin="12,9">
                                            <Border x:Name="Bar" Width="3" CornerRadius="{StaticResource RadiusXs}" HorizontalAlignment="Left"
                                                    Background="{DynamicResource Accent}" Visibility="Collapsed"/>
                                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        </Grid>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Panel}"/>
                                            <Setter TargetName="Bar" Property="Visibility" Value="Visible"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Lewa kolumna: tytuł + wyszukiwanie + kategorie -->
                <StackPanel Grid.Column="0" Width="214" Margin="20,24,6,16">
                    <TextBlock Text="{DynamicResource S.nav.settings}" Foreground="{DynamicResource TextPrim}" FontSize="{StaticResource FontHeading}" FontWeight="SemiBold" Margin="4,0,0,16"/>
                    <ui:TextBox x:Name="SettingsSearch" PlaceholderText="{DynamicResource S.set.search}" Margin="0,0,0,12"
                                TextChanged="SettingsSearch_TextChanged">
                        <ui:TextBox.Icon><ui:SymbolIcon Symbol="Search24"/></ui:TextBox.Icon>
                    </ui:TextBox>
                    <ListBox x:Name="SettingsCats" SelectionChanged="SettingsCat_Changed"
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource SettingsNavItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBoxItem Content="{DynamicResource S.set.iface}"/>
                        <ListBoxItem Content="{DynamicResource S.set.conn}"/>
                        <ListBoxItem Content="{DynamicResource S.set.behavior}"/>
                        <ListBoxItem Content="{DynamicResource S.set.autoconnect}"/>
                        <ListBoxItem Content="{DynamicResource S.set.profiles}"/>
                        <ListBoxItem Content="{DynamicResource S.set.data}"/>
                        <ListBoxItem Content="{DynamicResource S.nav.about}"/>
                    </ListBox>
                </StackPanel>

                <!-- Prawa kolumna: treść wybranej kategorii (lub wyniki wyszukiwania) -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="SettingsCards" Margin="12,24,40,24" MaxWidth="1400" HorizontalAlignment="Stretch">

                    <!-- Interfejs -->
                    <Border Padding="0">
                        <StackPanel HorizontalAlignment="Stretch">
                            <TextBlock Text="{DynamicResource S.set.iface}" Style="{DynamicResource SetPageHead}"/>
                            <TextBlock Text="{DynamicResource S.set.iface.sub}" Style="{DynamicResource SetPageSub}"/>

                            <TextBlock Text="{DynamicResource S.set.sec.appearance}" Style="{DynamicResource SetSec}"/>

                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.theme}" Style="{DynamicResource SetLbl}"/>
                                    <Border Grid.Column="1" Style="{DynamicResource SegBar}">
                                        <StackPanel x:Name="ThemeSeg" Orientation="Horizontal">
                                            <RadioButton Style="{DynamicResource Seg}" Tag="Dark" Content="{DynamicResource S.theme.dark}" Checked="SegSetting_Changed"/>
                                            <RadioButton Style="{DynamicResource Seg}" Tag="Light" Content="{DynamicResource S.theme.light}" Checked="SegSetting_Changed"/>
                                            <RadioButton Style="{DynamicResource Seg}" Tag="System" Content="{DynamicResource S.theme.system}" Checked="SegSetting_Changed"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <TextBlock Text="{DynamicResource S.set.themepreset}" Foreground="{DynamicResource TextSec}"
                                       FontSize="{StaticResource FontBody}" Margin="0,14,0,8"/>
                            <!-- Siatka presetów palety (Compass §4.9) — budowana w kodzie (BuildThemePresets). -->
                            <WrapPanel x:Name="ThemePresetGrid" Orientation="Horizontal" MaxWidth="780"/>

                            <Border Style="{DynamicResource SetRow}" Margin="0,16,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.accent}" Style="{DynamicResource SetLbl}"/>
                                    <!-- Próbnik akcentu (Compass §4.7): budowany w kodzie (BuildAccentSwatches). -->
                                    <WrapPanel x:Name="AccentSwatches" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.language}" Style="{DynamicResource SetLbl}"/>
                                    <ComboBox x:Name="SetLanguage" Grid.Column="1" Width="150" SelectionChanged="InterfaceSetting_Changed">
                                        <ComboBoxItem Content="Polski" Tag="pl"/>
                                        <ComboBoxItem Content="English" Tag="en"/>
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <Border Style="{DynamicResource SetRow}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource S.set.uiscale}" Style="{DynamicResource SetLbl}"/>
                                        <TextBlock Text="{DynamicResource S.set.uiscale.sub}" Style="{DynamicResource SetSub}"/>
                                    </StackPanel>
                                    <ui:TextBox x:Name="SetUiScale" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="{DynamicResource S.set.sec.list}" Style="{DynamicResource SetSec}"/>

                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.liststyle}" Style="{DynamicResource SetLbl}"/>
                                    <Border Grid.Column="1" Style="{DynamicResource SegBar}">
                                        <StackPanel x:Name="ListStyleSeg" Orientation="Horizontal">
                                            <RadioButton Style="{DynamicResource Seg}" Tag="Default" Content="{DynamicResource S.liststyle.default}" Checked="SegSetting_Changed"/>
                                            <RadioButton Style="{DynamicResource Seg}" Tag="Minimal" Content="{DynamicResource S.liststyle.minimal}" Checked="SegSetting_Changed"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Style="{DynamicResource SetRow}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.showlatency}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetShowLatency" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="{DynamicResource S.set.sec.advanced}" Style="{DynamicResource SetSec}"/>

                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.bardelay}" Style="{DynamicResource SetLbl}"/>
                                    <ui:TextBox x:Name="SetBarDelay" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.focuspeekopacity}" Style="{DynamicResource SetLbl}"/>
                                    <ui:TextBox x:Name="SetFocusPeekOpacity" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.termfontsize}" Style="{DynamicResource SetLbl}"/>
                                    <ui:TextBox x:Name="SetTermFontSize" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Style="{DynamicResource SetRow}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.border}" Style="{DynamicResource SetLbl}"/>
                                    <Border Grid.Column="1" Style="{DynamicResource SegBar}">
                                        <StackPanel x:Name="BorderSeg" Orientation="Horizontal">
                                            <RadioButton Style="{DynamicResource Seg}" Tag="" Content="{DynamicResource S.border.none}" Checked="SegSetting_Changed"/>
                                            <RadioButton Style="{DynamicResource Seg}" Tag="#2657D6" Content="{DynamicResource S.border.cobalt}" Checked="SegSetting_Changed"/>
                                            <RadioButton Style="{DynamicResource Seg}" Tag="System" Content="{DynamicResource S.border.system}" Checked="SegSetting_Changed"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Połączenie -->
                    <Border Padding="0">
                        <StackPanel HorizontalAlignment="Stretch">
                            <TextBlock Text="{DynamicResource S.set.conn}" Style="{DynamicResource SetPageHead}"/>
                            <TextBlock Text="{DynamicResource S.set.conn.sub}" Style="{DynamicResource SetPageSub}"/>

                            <TextBlock Text="{DynamicResource S.set.sec.rdpdefaults}" Style="{DynamicResource SetSec}"/>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.port}" Style="{DynamicResource SetLbl}"/>
                                    <ui:TextBox x:Name="SetDefaultPort" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.colordepth}" Style="{DynamicResource SetLbl}"/>
                                    <Border Grid.Column="1" Style="{DynamicResource SegBar}">
                                        <StackPanel x:Name="ColorDepthSeg" Orientation="Horizontal">
                                            <RadioButton Style="{DynamicResource Seg}" Tag="16" Content="16-bit"/>
                                            <RadioButton Style="{DynamicResource Seg}" Tag="24" Content="24-bit"/>
                                            <RadioButton Style="{DynamicResource Seg}" Tag="32" Content="32-bit"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.redirclip}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetRedirClip" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.redirdrives}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetRedirDrives" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="{DynamicResource S.set.sec.network}" Style="{DynamicResource SetSec}"/>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource S.set.timeout}" Style="{DynamicResource SetLbl}"/>
                                        <TextBlock Text="{DynamicResource S.set.timeout.sub}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ui:TextBox x:Name="SetProbeTimeout" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.autoreconnect}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetAutoReconnect" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource S.set.sec.profiles}" Style="{DynamicResource SetSec}" VerticalAlignment="Center"/>
                                <ui:Button Grid.Column="1" Content="{DynamicResource S.prof.add}" Appearance="Secondary" Click="AddProfile_Click"/>
                            </Grid>
                            <StackPanel x:Name="ConnProfilesList" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Zachowanie -->
                    <Border Padding="0">
                        <StackPanel HorizontalAlignment="Stretch">
                            <TextBlock Text="{DynamicResource S.set.behavior}" Style="{DynamicResource SetPageHead}"/>
                            <TextBlock Text="{DynamicResource S.set.behavior.sub}" Style="{DynamicResource SetPageSub}"/>

                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.reach}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetReachEnabled" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.reachinterval}" Style="{DynamicResource SetLbl}"/>
                                    <ui:TextBox x:Name="SetReachInterval" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.confirmclose}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetConfirmClose" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.connlog}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetConnLog" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.opennewwin}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetOpenNewWindow" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.immersive}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetImmersive" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.traymin}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetMinimizeToTray" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.hotkey}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetHotkey" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.restoreprompt}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetRestorePrompt" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Połącz na starcie -->
                    <Border Padding="0">
                        <StackPanel HorizontalAlignment="Stretch">
                            <TextBlock Text="{DynamicResource S.set.autoconnect}" Style="{DynamicResource SetPageHead}"/>
                            <TextBlock Text="{DynamicResource S.set.autoconnect.hint}" Style="{DynamicResource SetPageSub}"/>
                            <Border BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="10,6">
                                <ScrollViewer MaxHeight="440" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="AutoConnectList"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Profile poświadczeń -->
                    <Border Padding="0">
                        <StackPanel HorizontalAlignment="Stretch">
                            <TextBlock Text="{DynamicResource S.set.profiles}" Style="{DynamicResource SetPageHead}"/>
                            <TextBlock Text="{DynamicResource S.set.profiles.hint}" Style="{DynamicResource SetPageSub}"/>
                            <Border BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="10,6">
                                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="ProfilesList"/>
                                </ScrollViewer>
                            </Border>
                            <ui:Button Content="{DynamicResource S.prof.add}" Appearance="Secondary" Click="AddProfile_Click" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Dane -->
                    <Border Padding="0">
                        <StackPanel HorizontalAlignment="Stretch">
                            <TextBlock Text="{DynamicResource S.set.data}" Style="{DynamicResource SetPageHead}"/>
                            <TextBlock Text="{DynamicResource S.set.data.sub}" Style="{DynamicResource SetPageSub}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <TextBlock x:Name="SetDataPath" Foreground="{DynamicResource TextTer}" FontFamily="{DynamicResource Mono}"
                                           FontSize="{StaticResource FontSmall}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                <ui:Button Content="{DynamicResource S.set.openfolder}" Appearance="Secondary" Click="OpenDataFolder_Click" Margin="12,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <ui:Button Content="{DynamicResource S.set.exportprofile}" Appearance="Secondary" Click="ExportProfile_Click"/>
                                <ui:Button Content="{DynamicResource S.set.importprofile}" Appearance="Secondary" Click="ImportProfile_Click" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontSmall}" TextWrapping="Wrap" Margin="0,6,0,0"
                                       Text="{DynamicResource S.set.backupnote}"/>
                        </StackPanel>
                    </Border>

                    <!-- O aplikacji (Compass §4.6/§4.11): treść dawnego okna „O aplikacji" + aktualizacje + changelog -->
                    <Border Padding="0">
                        <StackPanel HorizontalAlignment="Stretch">
                            <TextBlock Text="{DynamicResource S.nav.about}" Style="{DynamicResource SetPageHead}"/>
                            <TextBlock Text="{DynamicResource S.set.about.sub}" Style="{DynamicResource SetPageSub}"/>

                            <!-- Karta z wersją -->
                            <Border Style="{DynamicResource Card}" Padding="16,14">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="pack://application:,,,/Assets/app.ico" Width="44" Height="44" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                        <TextBlock Text="Waypoint" FontSize="{StaticResource FontBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrim}"/>
                                        <TextBlock x:Name="AboutVersion" Foreground="{DynamicResource TextSec}" FontSize="{StaticResource FontBody}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Karta aktualizacji: „Masz najnowszą…" / „Dostępna aktualizacja — X" + Zainstaluj (kod ustawia stan) -->
                            <Border x:Name="AboutUpdateCard" Style="{DynamicResource Card}" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon x:Name="AboutUpdateIcon" Symbol="CheckmarkCircle24" FontSize="{StaticResource IconLg}"
                                                   Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,12,0">
                                        <TextBlock x:Name="AboutUpdateTitle" Foreground="{DynamicResource TextPrim}" FontSize="{StaticResource FontBodyLg}"
                                                   FontWeight="SemiBold" Text="{DynamicResource S.update.uptodate}"/>
                                        <TextBlock x:Name="AboutUpdateSub" Foreground="{DynamicResource TextSec}" FontSize="{StaticResource FontSmall}"
                                                   Margin="0,2,0,0" Visibility="Collapsed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:Button x:Name="AboutUpdateInstall" Visibility="Collapsed" Appearance="Primary"
                                                   Content="{DynamicResource S.about.install}" Click="Update_Click"/>
                                        <ui:Button x:Name="AboutCheckNow" Content="{DynamicResource S.set.checkupdatesnow}" Appearance="Secondary"
                                                   Click="CheckUpdatesNow_Click" Margin="8,0,0,0"/>
                                        <ui:Button Content="{DynamicResource S.about.whatsnew}" Appearance="Secondary" Click="AboutWhatsNew_Click" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource SetRow}" BorderThickness="0" Margin="2,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource S.set.checkupdates}" Style="{DynamicResource SetLbl}"/>
                                    <ui:ToggleSwitch x:Name="SetCheckUpdates" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Historia zmian (kurowana lista z Changelog.cs) -->
                            <TextBlock Text="{DynamicResource S.set.sec.changelog}" Style="{DynamicResource SetSec}"/>
                            <Border Style="{DynamicResource Card}" Padding="16,6">
                                <StackPanel x:Name="ChangelogList"/>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <ui:Button Content="{DynamicResource S.about.github}" Appearance="Secondary" Click="AboutRepo_Click"/>
                                <ui:Button Content="{DynamicResource S.about.license}" Appearance="Secondary" Click="AboutLicense_Click" Margin="8,0,0,0"/>
                                <ui:Button Content="{DynamicResource S.about.reportissue}" Appearance="Secondary" Click="AboutReportIssue_Click" Margin="8,0,0,0"/>
                                <ui:Button Content="{DynamicResource S.set.openfolder}" Appearance="Secondary" Click="OpenDataFolder_Click" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="AboutDataPath" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}"
                                       FontFamily="{DynamicResource Mono}" TextWrapping="Wrap" Margin="2,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ui:Button Content="{DynamicResource S.set.save}" Appearance="Primary" Click="SaveSettings_Click"/>
                        <TextBlock x:Name="SettingsStatus" Foreground="{DynamicResource Online}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Grid>
            </Grid>
        </Grid>

        <!-- Szybkie przełączanie z paska kart (tryb skupienia): popup = osobny HWND, rysuje się nad sesją -->
        <Popup x:Name="QuickSwitchPopup" Placement="Center" PlacementTarget="{Binding ElementName=BodyGrid}"
               StaysOpen="False" AllowsTransparency="True">
            <Border Background="{DynamicResource RailBg}" CornerRadius="{StaticResource RadiusLg}" Padding="8"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1" Width="460">
                <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.45"/></Border.Effect>
                <StackPanel>
                    <ui:TextBox x:Name="QuickSwitchSearch" PlaceholderText="{DynamicResource S.cmd.placeholder}"
                                Margin="0,0,0,6" TextChanged="QuickSwitchSearch_TextChanged" KeyDown="QuickSwitchSearch_KeyDown">
                        <ui:TextBox.Icon><ui:SymbolIcon Symbol="Search24"/></ui:TextBox.Icon>
                    </ui:TextBox>
                    <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock x:Name="QsSessionsHeader" Text="{DynamicResource S.fs.opensessions}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}"
                                       FontWeight="SemiBold" Margin="6,6,6,4"/>
                            <StackPanel x:Name="QsSessions"/>
                            <TextBlock x:Name="QsServersHeader" Text="{DynamicResource S.fs.allservers}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}"
                                       FontWeight="SemiBold" Margin="6,8,6,4"/>
                            <StackPanel x:Name="QsServers"/>
                            <TextBlock x:Name="QsActionsHeader" Text="{DynamicResource S.cmd.actions}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}"
                                       FontWeight="SemiBold" Margin="6,8,6,4"/>
                            <StackPanel x:Name="QsActions"/>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Lewy panel w trybie skupienia. Popup = osobny HWND, więc nakłada się na sesję (RDP/WebView2)
             BEZ zmiany jej rozmiaru — sesja się nie renegocjuje i nie miga. Rail+Sidebar są tu przenoszone
             na czas peeka (reparenting), a płynne wysunięcie robi animacja TranslateTransform. -->
        <Popup x:Name="FocusPeekPopup" Placement="Relative" PlacementTarget="{Binding ElementName=BodyGrid}"
               AllowsTransparency="True" StaysOpen="True" HorizontalOffset="0" VerticalOffset="0">
            <Border x:Name="FocusPeekClip" ClipToBounds="True" Width="280">
                <!-- Popup to osobny HWND i NIE dziedziczy RootScale (zoom UI). Bez tego przy zoomie ≠100%
                     peek renderował się w skali 100% (za duży) i był ucięty od dołu. Nadajemy mu tę samą
                     skalę co panel dokowany — ScaleY ustawiane w ShowFocusPeek. -->
                <Border.LayoutTransform>
                    <ScaleTransform x:Name="FocusPeekScale" ScaleX="1" ScaleY="1"/>
                </Border.LayoutTransform>
                <StackPanel x:Name="FocusPeekHost" Orientation="Horizontal" HorizontalAlignment="Left">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="FocusPeekSlide" X="-280"/>
                    </StackPanel.RenderTransform>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Strefa upuszczenia podziału ekranu: pojawia się przy przeciąganiu karty (Popup = osobny HWND,
             więc rysuje się NAD kontrolką RDP/airspace i może być celem upuszczenia). Upuszczenie sesji RDP
             dzieli ekran (przeciągana sesja → prawy panel). Rozmiar ustawiany w ShowSplitDropZone. -->
        <Popup x:Name="SplitDropZone" Placement="Relative" PlacementTarget="{Binding ElementName=SessionContainer}"
               AllowsTransparency="True" StaysOpen="True" HorizontalOffset="0" VerticalOffset="0">
            <Border x:Name="SplitDropBorder" AllowDrop="True" Background="{DynamicResource SplitDim}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1" Background="{DynamicResource AccentStrong}" BorderBrush="{DynamicResource AccentBright}" BorderThickness="3">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#x229F;" FontSize="{StaticResource IconXl}" Foreground="{DynamicResource TextOnColor}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource S.split.drop}" Foreground="{DynamicResource TextOnColor}"
                                       FontSize="{StaticResource FontBodyLg}" Margin="0,10,0,0" HorizontalAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Popup>

        <!-- floating fullscreen bar (Popup = osobny HWND -> rysuje się nad kontrolką RDP) -->
        <Popup x:Name="FsPopup" Placement="Custom" PlacementTarget="{Binding ElementName=HotZone}"
               AllowsTransparency="True" StaysOpen="True" MouseLeave="FsPopup_MouseLeave">
            <Border Background="{DynamicResource FsBarBg}" CornerRadius="{StaticResource RadiusLg}" Padding="14,7" Margin="12,4,12,12"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <Thumb x:Name="FsBarThumb" Width="20" Cursor="SizeWE" DragDelta="FsBarThumb_DragDelta"
                               Margin="0,0,10,0" ToolTip="{DynamicResource S.fs.drag}">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="Transparent">
                                        <TextBlock Text="⠿" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextTer}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                        <TextBlock x:Name="FsName" Text="—" Foreground="{DynamicResource TextPrim}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Border Width="1" Background="{DynamicResource Border}" Margin="12,2"/>
                        <ui:Button x:Name="InnyBtn" Content="{DynamicResource S.fs.others}" Appearance="Secondary" Click="ToggleFlyout_Click"/>
                        <Border Width="1" Background="{DynamicResource Border}" Margin="12,2"/>
                        <ui:Button x:Name="PinBtn" Content="{DynamicResource S.fs.pin}" Appearance="Secondary" Click="TogglePin_Click"/>
                        <Border Width="1" Background="{DynamicResource Border}" Margin="12,2"/>
                        <Button Style="{DynamicResource IconBtn}" Click="Minimize_Click" ToolTip="{DynamicResource S.tip.minimize}">
                            <TextBlock Text="&#x2212;" FontSize="{StaticResource IconMd}" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center"/>
                        </Button>
                        <ui:Button Content="{DynamicResource S.fs.restore}" Appearance="Secondary" Click="Fullscreen_Click" Margin="6,0,0,0"/>
                    </StackPanel>

                    <!-- flyout "inne połączenia" -->
                    <Border x:Name="FsFlyout" Visibility="Collapsed" Width="300" Margin="0,8,0,0"
                            Background="{DynamicResource FsFlyoutBg}" CornerRadius="{StaticResource RadiusMd}" Padding="8">
                        <StackPanel>
                            <ui:TextBox x:Name="FsFlyoutSearch" PlaceholderText="{DynamicResource S.search}"
                                        Margin="0,0,0,6" TextChanged="FsFlyoutSearch_TextChanged">
                                <ui:TextBox.Icon><ui:SymbolIcon Symbol="Search24"/></ui:TextBox.Icon>
                            </ui:TextBox>
                            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource S.fs.opensessions}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}"
                                               FontWeight="SemiBold" Margin="6,6,6,4"/>
                                    <StackPanel x:Name="FlyoutSessions"/>
                                    <TextBlock Text="{DynamicResource S.fs.allservers}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontCaption}"
                                               FontWeight="SemiBold" Margin="6,8,6,4"/>
                                    <StackPanel x:Name="FlyoutServers"/>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</ui:FluentWindow>
