<ui:FluentWindow x:Class="RdpManager.RestAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="" Width="680" Height="440"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" MinWidth="560" MinHeight="360"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" Background="{DynamicResource CanvasBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="WinTitleBar" Grid.Row="0" Title=""/>

        <Grid Grid.Row="1" Margin="{StaticResource DialogContentMarginTight}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Kolekcja (korzeń) + foldery -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{DynamicResource S.rest.authmgr.list}" Foreground="{DynamicResource TextSec}"
                           FontWeight="SemiBold" Margin="2,0,0,6"/>
                <ListBox Grid.Row="1" x:Name="EntryList" DisplayMemberPath="Label" SelectionChanged="Entry_Changed"
                         Foreground="{DynamicResource TextPrim}"
                         BorderThickness="1" BorderBrush="{DynamicResource Border}" Background="Transparent"/>
            </Grid>

            <!-- Szczegóły wybranego poziomu -->
            <Grid Grid.Column="1" Margin="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="DetailHeader" Foreground="{DynamicResource TextSec}"
                           FontWeight="SemiBold" Margin="2,0,0,10" TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource S.rest.auth.type}" Foreground="{DynamicResource TextTer}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="{StaticResource FontBody}"/>
                    <ComboBox x:Name="TypeCombo" Width="220" SelectionChanged="Type_Changed" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <!-- Bearer: TextBox (jak w konsoli) — token widoczny, można wpisać {{zmienną}} środowiska;
                         kolor sygnalizuje, czy zmienna istnieje (niebieski) czy nie (czerwony). -->
                    <StackPanel x:Name="BearerPanel" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource S.rest.auth.token}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontBody}" Margin="0,0,0,3"/>
                        <TextBox x:Name="TokenBox" MaxWidth="420" MinWidth="320" HorizontalAlignment="Left"
                                 FontFamily="{DynamicResource Mono}" TextChanged="Token_TextChanged"
                                 Background="Transparent" Foreground="{DynamicResource TextPrim}" CaretBrush="{DynamicResource TextPrim}"
                                 BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="4,4"/>
                        <TextBlock Text="{DynamicResource S.rest.auth.tokenvar}" Foreground="{DynamicResource TextTer}"
                                   FontSize="{StaticResource FontSmall}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Basic -->
                    <StackPanel x:Name="BasicPanel" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource S.rest.auth.user}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontBody}" Margin="0,0,0,3"/>
                        <TextBox x:Name="UserBox" MaxWidth="420" MinWidth="320" HorizontalAlignment="Left" Margin="0,0,0,8"
                                 Background="Transparent" Foreground="{DynamicResource TextPrim}" CaretBrush="{DynamicResource TextPrim}"
                                 BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="4,4"/>
                        <TextBlock Text="{DynamicResource S.rest.auth.pass}" Foreground="{DynamicResource TextTer}" FontSize="{StaticResource FontBody}" Margin="0,0,0,3"/>
                        <PasswordBox x:Name="PassBox" MaxWidth="420" MinWidth="320" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Dziedzicz: skąd faktycznie weźmie auth -->
                    <TextBlock x:Name="InheritHint" Visibility="Collapsed" Foreground="{DynamicResource TextTer}"
                               FontSize="{StaticResource FontSmall}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                    <TextBlock Text="{DynamicResource S.rest.auth.hint}" Foreground="{DynamicResource TextTer}"
                               FontSize="{StaticResource FontSmall}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogButtonRowMargin}">
            <ui:Button Content="{DynamicResource S.rest.env.close}" Appearance="Primary" Click="Close_Click" MinWidth="90" IsDefault="True" IsCancel="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
