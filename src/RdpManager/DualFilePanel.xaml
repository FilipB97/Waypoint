<UserControl x:Class="RdpManager.DualFilePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Background="{DynamicResource Panel}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="220"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="220"/>
        </Grid.ColumnDefinitions>

        <!-- Lewy: lokalny system plików -->
        <ContentControl x:Name="LocalHost" Grid.Column="0"/>

        <!-- Środek: transfer w obie strony -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="7,0">
            <ui:Button x:Name="PushBtn" Appearance="Secondary" ToolTip="{DynamicResource S.dual.push}"
                       Click="ToRemote_Click" Width="42" Height="36" Margin="0,0,0,10" Padding="0">
                <ui:SymbolIcon Symbol="ArrowRight24"/>
            </ui:Button>
            <ui:Button x:Name="PullBtn" Appearance="Secondary" ToolTip="{DynamicResource S.dual.pull}"
                       Click="ToLocal_Click" Width="42" Height="36" Padding="0">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
        </StackPanel>

        <!-- Prawy: zdalny system plików (SFTP/FTP) -->
        <ContentControl x:Name="RemoteHost" Grid.Column="2"/>
    </Grid>
</UserControl>
