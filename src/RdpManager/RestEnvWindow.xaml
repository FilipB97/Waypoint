<ui:FluentWindow x:Class="RdpManager.RestEnvWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="" Width="680" Height="460"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" MinWidth="560" MinHeight="360"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
    <Window.Resources>
        <Style x:Key="EnvIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource Accent}" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Border x:Name="FocusRing" CornerRadius="{StaticResource RadiusSm}" BorderThickness="2" BorderBrush="Transparent" IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="0.12" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/></Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="BorderBrush" Value="{DynamicResource Accent}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Wiersz listy środowisk: akcentowa nakładka hover/zaznaczenia (jak listy w reszcie aplikacji)
             zamiast systemowego niebieskiego podświetlenia ListBoxa, które gryzło się z motywem. -->
        <Style x:Key="EnvListItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrim}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource Accent}" Opacity="0"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.10"/></Trigger>
                            <!-- Po hoverze — zaznaczenie ma wygrywać (ostatni pasujący trigger ustawia wartość). -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.22"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="EnvVarRow">
            <Grid Height="34" Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Margin="0,0,8,0" VerticalContentAlignment="Center"
                         Foreground="{DynamicResource TextPrim}" CaretBrush="{DynamicResource TextPrim}"
                         Background="Transparent" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                         Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Grid.Column="1" Margin="0,0,8,0" VerticalContentAlignment="Center"
                         Foreground="{DynamicResource TextPrim}" CaretBrush="{DynamicResource TextPrim}"
                         Background="Transparent" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="2" Style="{StaticResource EnvIconBtn}" Width="28" Padding="0" Click="DeleteVar_Click"
                        ToolTip="{DynamicResource S.rest.remove}" AutomationProperties.Name="{DynamicResource S.rest.remove}">
                    <ui:SymbolIcon Symbol="Dismiss20" FontSize="{StaticResource IconSm}"/>
                </Button>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="WinTitleBar" Grid.Row="0" Title=""/>

        <Grid Grid.Row="1" Margin="{StaticResource DialogContentMarginTight}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Środowiska: lista + pasek akcji. Celowo BEZ nagłówka kolumny — okno nazywa się
                 „Środowiska", więc nagłówek dublował pasek tytułu (zgłoszone w przeglądzie UX). -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox Grid.Row="0" x:Name="EnvList" DisplayMemberPath="Name" SelectionChanged="Env_Changed"
                         ItemContainerStyle="{StaticResource EnvListItem}" Padding="4"
                         Foreground="{DynamicResource TextPrim}"
                         BorderThickness="1" BorderBrush="{DynamicResource Border}" Background="Transparent"/>
                <!-- Akcja główna (Dodaj, z etykietą — jak „Dodaj" przy zmiennych) po lewej; operacje na
                     zaznaczonym (nazwa/usuń) i import po prawej, z oddechem zamiast upchanego rzędu ikon. -->
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource EnvIconBtn}" Foreground="{DynamicResource Accent}"
                            ToolTip="{DynamicResource S.rest.env.newenv}" AutomationProperties.Name="{DynamicResource S.rest.env.newenv}" Click="AddEnv_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Add20" FontSize="{StaticResource IconSm}"/>
                            <TextBlock Text="{DynamicResource S.rest.add}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource EnvIconBtn}" Width="32" Margin="0,0,4,0" ToolTip="{DynamicResource S.rest.rename}" AutomationProperties.Name="{DynamicResource S.rest.rename}" Click="RenameEnv_Click">
                            <ui:SymbolIcon Symbol="Rename24" FontSize="{StaticResource IconMd}"/>
                        </Button>
                        <Button Style="{StaticResource EnvIconBtn}" Width="32" ToolTip="{DynamicResource S.rest.delete}" AutomationProperties.Name="{DynamicResource S.rest.delete}" Click="DeleteEnv_Click">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="{StaticResource IconMd}"/>
                        </Button>
                        <Border Width="1" Margin="6,6" Background="{DynamicResource Border}"/>
                        <Button Style="{StaticResource EnvIconBtn}" Width="32" ToolTip="{DynamicResource S.rest.env.import}" AutomationProperties.Name="{DynamicResource S.rest.env.import}" Click="ImportEnv_Click">
                            <ui:SymbolIcon Symbol="ArrowImport24" FontSize="{StaticResource IconMd}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Zmienne -->
            <Grid Grid.Column="1" Margin="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Nagłówek z nazwą zaznaczonego środowiska („Zmienne — Prod") — ustawiany w code-behind. -->
                <TextBlock Grid.Row="0" x:Name="VarsHeader" Text="{DynamicResource S.rest.env.vars}" Foreground="{DynamicResource TextSec}"
                           FontWeight="SemiBold" Margin="2,0,0,4" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="1" Text="{DynamicResource S.rest.env.hint}" Foreground="{DynamicResource TextTer}"
                           FontSize="{StaticResource FontSmall}" TextWrapping="Wrap" Margin="2,0,0,6"/>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="VarsList" ItemTemplate="{StaticResource EnvVarRow}" Margin="2,0"/>
                </ScrollViewer>
                <Button Grid.Row="3" HorizontalAlignment="Left" Margin="2,6,0,0" Style="{StaticResource EnvIconBtn}"
                        Click="AddVar_Click" Foreground="{DynamicResource Accent}" AutomationProperties.Name="{DynamicResource S.rest.add}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add20" FontSize="{StaticResource IconSm}"/>
                        <TextBlock Text="{DynamicResource S.rest.add}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogButtonRowMargin}">
            <ui:Button Content="{DynamicResource S.rest.env.close}" Appearance="Primary" Click="Close_Click" MinWidth="90" IsDefault="True" IsCancel="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
