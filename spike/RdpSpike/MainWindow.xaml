<Window x:Class="RdpSpike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="RDP Spike — Faza 1" Height="720" Width="1100"
        Background="#1F2023"
        Loaded="Window_Loaded" KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="#272830"/>
            <Setter Property="Foreground" Value="#F1F2F4"/>
            <Setter Property="BorderBrush" Value="#3A3B44"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9DA0A8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar (chrome — collapsed in fullscreen) -->
        <StackPanel x:Name="Toolbar" Grid.Row="0" Orientation="Horizontal"
                    Background="#212226" Margin="0" VerticalAlignment="Center">
            <TextBlock Text="Host:" Margin="10,0,4,0"/>
            <TextBox x:Name="HostBox" Width="150" Text="10.10.15.17" VerticalContentAlignment="Center" Margin="0,6"/>
            <TextBlock Text="Użytkownik:" Margin="12,0,4,0"/>
            <TextBox x:Name="UserBox" Width="130" VerticalContentAlignment="Center" Margin="0,6"/>
            <TextBlock Text="Hasło:" Margin="12,0,4,0"/>
            <PasswordBox x:Name="PassBox" Width="130" VerticalContentAlignment="Center" Margin="0,6"/>
            <Button Content="Połącz" Click="Connect_Click" Margin="12,0,3,0"/>
            <Button Content="Rozłącz" Click="Disconnect_Click"/>
            <Button Content="Pełny ekran (F11)" Click="Fullscreen_Click" Margin="12,0,3,0"/>
            <Button Content="Otwórz pasek FS" Click="ShowBar_Click"/>
        </StackPanel>

        <!-- Hot zone: a 6px WPF strip ABOVE the airspace control, so WPF can catch MouseEnter -->
        <Border x:Name="HotZone" Grid.Row="1" Background="#2A2B33" MouseEnter="HotZone_MouseEnter"/>

        <!-- RDP ActiveX host -->
        <wfi:WindowsFormsHost x:Name="RdpHost" Grid.Row="2"/>

        <!-- Status bar -->
        <Border x:Name="StatusBar" Grid.Row="3" Background="#1C1D20" Padding="10,4">
            <TextBlock x:Name="StatusText" Text="Gotowy. Wpisz hasło i kliknij Połącz."/>
        </Border>

        <!-- Fullscreen floating bar as a Popup (separate top-level HWND -> renders OVER the ActiveX) -->
        <Popup x:Name="FsPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=HotZone}"
               AllowsTransparency="True" StaysOpen="True" MouseLeave="FsPopup_MouseLeave">
            <Border Background="#DD212226" CornerRadius="10" Padding="14,8" Margin="12"
                    BorderBrush="#33FFFFFF" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="FsName" Text="prod-web1" Foreground="#F1F2F4" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Width="1" Background="#33FFFFFF" Margin="12,2" />
                    <Button Content="inne połączenia ▾" Click="ShowBar_Click"/>
                    <Border Width="1" Background="#33FFFFFF" Margin="12,2" />
                    <Button Content="Przywróć okno" Click="Fullscreen_Click"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
